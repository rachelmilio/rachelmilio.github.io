    <owl:Class rdf:about="#Legal_Body_that_convenes_Council_and_Assembly_has_50_members_made_up_of_council_members_in_an_order_determined_by_lot_serves_for_one_tenth_of_a_year">
        <rdfs:label xml:lang="en">Prytaneis</rdfs:label>
        <skos:prefLabel xml:lang="en">Prytaneis</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that convenes Council and Assembly, has 50 members, made up of council members in an order determined by lot, serves for one tenth of a year.</skos:definition>
        <rdfs:label xml:lang="en">Presidents</rdfs:label>
        <skos:altLabel xml:lang="en">Presidents</skos:altLabel>
        <skos:definition xml:lang="en">Legal Body that convenes Council and Assembly, has 50 members, made up of council members in an order determined by lot, serves for one tenth of a year.</skos:definition>
        <rdfs:label xml:lang="grc">πρυτάνεις</rdfs:label>
        <skos:prefLabel xml:lang="grc">πρυτάνεις</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that convenes Council and Assembly, has 50 members, made up of council members in an order determined by lot, serves for one tenth of a year.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 2.60: " προγράψαι τοὺς πρυτάνεις ἐκκλησίας δύο κατὰ τὸν νόμον, ἐν δὲ ταύταις βουλεύσασθαι περὶ τῆς εἰρήνης Ἀθηναίους"</skos:example>
