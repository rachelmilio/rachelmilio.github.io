        <owl:disjointWith rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_religious_suits_such_as_impiety_indictments_and_homicide_suits_held_by_one_person"/>
