    <owl:Class rdf:about="#Legal_Body_that_can_arrest_denounced_defendants_and_execute_those_caught_in_the_act_that_supervises_suits_initiated_via_arrests_held_by_11_people_chosen_by_lot_serves_a_one_year_term">
        <rdfs:label xml:lang="en">Eleven</rdfs:label>
        <skos:prefLabel xml:lang="en">Eleven</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that can arrest denounced defendants and execute those caught in the act, that supervises suits initiated via arrests, held by 11 people, chosen by lot, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">οἱ ἕνδεκα‎</rdfs:label>
        <skos:prefLabel xml:lang="grc">οἱ ἕνδεκα‎</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that can arrest denounced defendants and execute those caught in the act, that supervises suits initiated via arrests, held by 11 people, chosen by lot, serves a one year term.</skos:definition>
        <skos:example xml:lang="grc">Isaeus 4.28: " οὗτος γάρ, ὅτ᾽ ἐπεδήμει ἐνθάδε, πρῶτον μὲν εἰς τὸ δεσμωτήριον ὡς κλέπτης ὢν ἐπ᾽ αὐτοφώρῳ ἀπήχθη, τότε δὲ ἀφεθεὶς μεθ᾽ ἑτέρων τινῶν ὑπὸ τῶν ἕνδεκα"</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_Body"/>
        <owl:disjointWith rdf:resource="#Legal_Body_that_convenes_Council_and_Assembly_has_50_members_made_up_of_council_members_in_an_order_determined_by_lot_serves_for_one_tenth_of_a_year"/>
