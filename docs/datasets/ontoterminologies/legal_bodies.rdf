    <owl:Class rdf:about="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_lawsuits_against_other_officials_such_as_impeachments_indictments_for_illegal_proposals_and_scrutinies_held_by_6_people">
        <rdfs:label xml:lang="en">Law-Givers</rdfs:label>
        <skos:altLabel xml:lang="en">Law-Givers</skos:altLabel>
        <skos:definition xml:lang="en">Archon that supervises lawsuits against other officials such as impeachments indictments for illegal proposals and scrutinies, held by 6 people.</skos:definition>
        <rdfs:label xml:lang="en">Thesmothetai</rdfs:label>
        <skos:prefLabel xml:lang="en">Thesmothetai</skos:prefLabel>
        <skos:definition xml:lang="en">Archon that supervises lawsuits against other officials such as impeachments indictments for illegal proposals and scrutinies, held by 6 people.</skos:definition>
        <rdfs:label xml:lang="grc">θεσμοθέται</rdfs:label>
        <skos:prefLabel xml:lang="grc">θεσμοθέται</skos:prefLabel>
        <skos:definition xml:lang="grc">ἄρχων that supervises lawsuits against other officials such as impeachments indictments for illegal proposals and scrutinies, held by 6 people.</skos:definition>
        <skos:example xml:lang="grc">Isoc. 20.2: " ἔπειτα τῶν μὲν ἄλλων ἐγκλημάτων αὐτῷ τῷ παθόντι μόνον ὁ δράσας ὑπόδικός ἐστιν: περὶ δὲ τῆς ὕβρεως, ὡς κοινοῦ τοῦ πράγματος ὄντος, ἔξεστι τῷ βουλομένῳ τῶν πολιτῶν γραψαμένῳ πρὸς τοὺς θεσμοθέτας εἰσελθεῖν εἰς ὑμᾶς."</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term"/>
        <owl:disjointWith rdf:resource="#Legal_Body_that_judges_the_majority_of_legal_proceedings_has_a_size_that_varies_based_on_case_selected_from_a_pool_of_6000_chosen_by_lot_from_male_citizens_over_30_serves_a_one_year_term"/>
        <owl:disjointWith rdf:resource="#Legal_Body_that_supervises_euthanai_initiated_by_public_held_by_10_people_chosen_by_lot_serves_a_one_year_term"/>
        <owl:disjointWith rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_family_law_for_metics_held_by_one_person"/>
