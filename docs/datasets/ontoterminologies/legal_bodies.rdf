    <owl:Class rdf:about="#Legal_Body_that_judges_the_majority_of_legal_proceedings_has_a_size_that_varies_based_on_case_selected_from_a_pool_of_6000_chosen_by_lot_from_male_citizens_over_30_serves_a_one_year_term">
