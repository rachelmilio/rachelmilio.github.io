	<!--  SKOS Concept Scheme -->

    <skos:ConceptScheme rdf:about="http://www.ontologia.fr/OTB/legal_bodies">
        <dc:title>Athenian-Legal-Bodies</dc:title>
        <dc:description>This is version 2.0 of a database for the PhD "Semantic Annotation and Attic Oratory" that defines the primary legal bodies in Classical Athenian courts c. 419 BC to 323 BC. I define a legal body as an individual or group who either proceeds over, judges, or is otherwise involved in a legal proceeding. This work draws upon the corpus of Attic oratory and the Pseudo-Aristotelian Athenian constitution, as well as The Law of Ancient Athens by David D. Phillips and the Shape of Athenian Law by S.C. Todd. </dc:description>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-06</dc:issued>
        <dc:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-10-10</dc:modified>
        <dc:creator>Rachel Milio</dc:creator>
        <dc:publisher>University of Crete</dc:publisher>
    </skos:ConceptScheme>

	<!--  SKOS Concepts -->

    <skos:Concept rdf:about="#Legal_Body_that_supervises_military_related_legal_proceedings_that_commands_the_military_held_by_10_people_elected_from_each_tribe_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Generals</rdfs:label>
        <skos:prefLabel xml:lang="en">Generals</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that supervises military related legal proceedings, that commands the military, held by 10 people, elected from each tribe, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">στρατηγοί</rdfs:label>
        <skos:prefLabel xml:lang="grc">στρατηγοί</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that supervises military related legal proceedings, that commands the military, held by 10 people, elected from each tribe, serves a one year term.</skos:definition>
        <skos:example xml:lang="grc">Dem. 4.25: " τὰς προφάσεις ἀφελεῖν καὶ τοῦ στρατηγοῦ καὶ τῶν στρατιωτῶν, μισθὸν πορίσαντας καὶ στρατιώτας οἰκείους ὥσπερ ἐπόπτας τῶν στρατηγουμένων παρακαταστήσαντας." </skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Archon</rdfs:label>
        <skos:prefLabel xml:lang="en">Archon</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that holds preliminary hearings and schedule cases, chosen by lot, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="en">Magistrate</rdfs:label>
        <skos:altLabel xml:lang="en">Magistrate</skos:altLabel>
        <skos:definition xml:lang="en">Legal Body that holds preliminary hearings and schedule cases, chosen by lot, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">ἄρχων</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἄρχων</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that holds preliminary hearings and schedule cases, chosen by lot, serves a one year term.</skos:definition>
        <skos:broader rdf:resource="#Legal_Body"/>
        <skos:narrower rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_lawsuits_against_other_officials_such_as_impeachments_indictments_for_illegal_proposals_and_scrutinies_held_by_6_people"/>
        <skos:narrower rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_family_lawsuits_for_citizens_held_by_one_person"/>
        <skos:narrower rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_family_law_for_metics_held_by_one_person"/>
        <skos:narrower rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_religious_suits_such_as_impiety_indictments_and_homicide_suits_held_by_one_person"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <skos:topConceptOf rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Legal Body</rdfs:label>
        <skos:prefLabel xml:lang="en">Legal Body</skos:prefLabel>
        <skos:definition xml:lang="en"> is an office of Athenian law.</skos:definition>
        <rdfs:label xml:lang="grc">τέλος</rdfs:label>
        <skos:prefLabel xml:lang="grc">τέλος</skos:prefLabel>
        <skos:definition xml:lang="grc"> is an office of Athenian law.</skos:definition>
        <skos:narrower rdf:resource="#Legal_Body_that_arbitrates_private_lawsuits_concerning_up_to_10_drachmas_that_supervises_private_lawsuits_of_more_than_10_drachmas_has_40_members_chosen_by_lot_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_convenes_Council_and_Assembly_has_50_members_made_up_of_council_members_in_an_order_determined_by_lot_serves_for_one_tenth_of_a_year"/>
        <skos:narrower rdf:resource="#Legal_Body_that_deliberates_over_agenda_for_Assembly_that_judges_scrutiny_of_pension_recipients_has_500_members_chosen_by_lot_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_judges_presentations_that_deliberates_over_political_issues_made_up_of_all_adult_male_citizens"/>
        <skos:narrower rdf:resource="#Legal_Body_that_judges_suits_for_intentional_homicide_intentional_wounding_and_destruction_of_sacred_olive_trees_that_investigates_reports_of_treason_made_up_of_all_former_archons_becomes_a_member_after_archonship_serves_for_the_remainder_of_life"/>
        <skos:narrower rdf:resource="#Legal_Body_that_judges_the_majority_of_legal_proceedings_has_a_size_that_varies_based_on_case_selected_from_a_pool_of_6000_chosen_by_lot_from_male_citizens_over_30_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_judges_unintentional_and_justifiable_homicide_cases_has_51_members_selected_from_Council_of_Areopagus_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_supervises_military_related_legal_proceedings_that_commands_the_military_held_by_10_people_elected_from_each_tribe_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_can_arrest_denounced_defendants_and_execute_those_caught_in_the_act_that_supervises_suits_initiated_via_arrests_held_by_11_people_chosen_by_lot_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_prosecutes_euthanai_brought_forward_by_logistai_held_by_10_people_chosen_by_lot_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_supervises_euthanai_initiated_by_public_held_by_10_people_chosen_by_lot_serves_a_one_year_term"/>
        <skos:narrower rdf:resource="#Legal_Body_that_arbitrates_private_cases_concerning_more_than_ten_drachmas_made_up_of_all_eligible_citizens_over_59_from_all_male_citizens_over_59_serves_for_the_remainder_of_life"/>
        <skos:narrower rdf:resource="#Legal_Body_that_examines_the_financial_records_of_magistrates_that_supervises_euthanai_for_embezzlement_and_bribes_held_by_10_people_elected_from_Council_of_500_serves_for_one_tenth_of_a_year"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_judges_unintentional_and_justifiable_homicide_cases_has_51_members_selected_from_Council_of_Areopagus_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Ephetai</rdfs:label>
        <skos:prefLabel xml:lang="en">Ephetai</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that judges unintentional and justifiable homicide cases, has 51 members, selected from Council of Areopagus, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">ἐφέται</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἐφέται</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that judges unintentional and justifiable homicide cases, has 51 members, selected from Council of Areopagus, serves a one year term.</skos:definition>
        <skos:example xml:lang="grc">Dem. 23.37: "ἐὰν δέ τις τὸν ἀνδροφόνον κτείνῃ ἢ αἴτιος ᾖ φόνου, ἀπεχόμενον ἀγορᾶς ἐφορίας καὶ ἄθλων καὶ ἱερῶν Ἀμφικτυονικῶν, ὥσπερ τὸν Ἀθηναῖον κτείναντα, ἐν τοῖς αὐτοῖς ἐνέχεσθαι, διαγιγνώσκειν δὲ τοὺς ἐφέτας."</skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_deliberates_over_agenda_for_Assembly_that_judges_scrutiny_of_pension_recipients_has_500_members_chosen_by_lot_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Council of 500</rdfs:label>
        <skos:prefLabel xml:lang="en">Council of 500</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that deliberates over agenda for Assembly, that judges scrutiny of pension recipients, has 500 members, chosen by lot, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">βουλὴ οἱ πεντακόσιοι</rdfs:label>
        <skos:prefLabel xml:lang="grc">βουλὴ οἱ πεντακόσιοι</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that deliberates over agenda for Assembly, that judges scrutiny of pension recipients, has 500 members, chosen by lot, serves a one year term.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 3.2: "ἐβουλόμην μὲν οὖν, ὦ ἄνδρες Ἀθηναῖοι, καὶ τὴν βουλὴν τοὺς πεντακοσίους καὶ τὰς ἐκκλησίας ὑπὸ τῶν ἐφεστηκότων ὀρθῶς διοικεῖσθαι"</skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_lawsuits_against_other_officials_such_as_impeachments_indictments_for_illegal_proposals_and_scrutinies_held_by_6_people">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Law-Givers</rdfs:label>
        <skos:altLabel xml:lang="en">Law-Givers</skos:altLabel>
        <skos:definition xml:lang="en">Archon that supervises lawsuits against other officials such as impeachments indictments for illegal proposals and scrutinies, held by 6 people.</skos:definition>
        <rdfs:label xml:lang="en">Thesmothetai</rdfs:label>
        <skos:prefLabel xml:lang="en">Thesmothetai</skos:prefLabel>
        <skos:definition xml:lang="en">Archon that supervises lawsuits against other officials such as impeachments indictments for illegal proposals and scrutinies, held by 6 people.</skos:definition>
        <rdfs:label xml:lang="grc">θεσμοθέται</rdfs:label>
        <skos:prefLabel xml:lang="grc">θεσμοθέται</skos:prefLabel>
        <skos:definition xml:lang="grc">ἄρχων that supervises lawsuits against other officials such as impeachments indictments for illegal proposals and scrutinies, held by 6 people.</skos:definition>
        <skos:example xml:lang="grc">Isoc. 20.2: " ἔπειτα τῶν μὲν ἄλλων ἐγκλημάτων αὐτῷ τῷ παθόντι μόνον ὁ δράσας ὑπόδικός ἐστιν: περὶ δὲ τῆς ὕβρεως, ὡς κοινοῦ τοῦ πράγματος ὄντος, ἔξεστι τῷ βουλομένῳ τῶν πολιτῶν γραψαμένῳ πρὸς τοὺς θεσμοθέτας εἰσελθεῖν εἰς ὑμᾶς."</skos:example>
        <skos:broader rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_convenes_Council_and_Assembly_has_50_members_made_up_of_council_members_in_an_order_determined_by_lot_serves_for_one_tenth_of_a_year">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Prytaneis</rdfs:label>
        <skos:prefLabel xml:lang="en">Prytaneis</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that convenes Council and Assembly, has 50 members, made up of council members in an order determined by lot, serves for one tenth of a year.</skos:definition>
        <rdfs:label xml:lang="en">Presidents</rdfs:label>
        <skos:altLabel xml:lang="en">Presidents</skos:altLabel>
        <skos:definition xml:lang="en">Legal Body that convenes Council and Assembly, has 50 members, made up of council members in an order determined by lot, serves for one tenth of a year.</skos:definition>
        <rdfs:label xml:lang="grc">πρυτάνεις</rdfs:label>
        <skos:prefLabel xml:lang="grc">πρυτάνεις</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that convenes Council and Assembly, has 50 members, made up of council members in an order determined by lot, serves for one tenth of a year.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 2.60: " προγράψαι τοὺς πρυτάνεις ἐκκλησίας δύο κατὰ τὸν νόμον, ἐν δὲ ταύταις βουλεύσασθαι περὶ τῆς εἰρήνης Ἀθηναίους"</skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_can_arrest_denounced_defendants_and_execute_those_caught_in_the_act_that_supervises_suits_initiated_via_arrests_held_by_11_people_chosen_by_lot_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Eleven</rdfs:label>
        <skos:prefLabel xml:lang="en">Eleven</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that can arrest denounced defendants and execute those caught in the act, that supervises suits initiated via arrests, held by 11 people, chosen by lot, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">οἱ ἕνδεκα‎</rdfs:label>
        <skos:prefLabel xml:lang="grc">οἱ ἕνδεκα‎</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that can arrest denounced defendants and execute those caught in the act, that supervises suits initiated via arrests, held by 11 people, chosen by lot, serves a one year term.</skos:definition>
        <skos:example xml:lang="grc">Isaeus 4.28: " οὗτος γάρ, ὅτ᾽ ἐπεδήμει ἐνθάδε, πρῶτον μὲν εἰς τὸ δεσμωτήριον ὡς κλέπτης ὢν ἐπ᾽ αὐτοφώρῳ ἀπήχθη, τότε δὲ ἀφεθεὶς μεθ᾽ ἑτέρων τινῶν ὑπὸ τῶν ἕνδεκα"</skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q125492782"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_arbitrates_private_lawsuits_concerning_up_to_10_drachmas_that_supervises_private_lawsuits_of_more_than_10_drachmas_has_40_members_chosen_by_lot_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Forty</rdfs:label>
        <skos:prefLabel xml:lang="en">Forty</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that arbitrates private lawsuits concerning up to 10 drachmas, that supervises private lawsuits of more than 10 drachmas, has 40 members, chosen by lot, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">τετταράκοντα</rdfs:label>
        <skos:prefLabel xml:lang="grc">τετταράκοντα</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that arbitrates private lawsuits concerning up to 10 drachmas, that supervises private lawsuits of more than 10 drachmas, has 40 members, chosen by lot, serves a one year term.</skos:definition>
        <skos:example xml:lang="grc">Isoc. 15.237: "ἐν γὰρ ταῖς σανίσι ταῖς ὑπὸ τῶν ἀρχόντων ἐκτιθεμέναις ἀναγκαῖόν ἐστιν, ἐν μὲν ταῖς ὑπὸ τῶν θεσμοθετῶν ἀμφοτέρους ἐνεῖναι, τούς τε τὴν πόλιν ἀδικοῦντας καὶ τοὺς συκοφαντοῦντας, ἐν δὲ ταῖς τῶν ἕνδεκα τούς τε κακουργοῦντας καὶ τοὺς τούτοις ἐφεστῶτας, ἐν δὲ ταῖς τῶν τετταράκοντα τούς τ᾽ ἐν τοῖς ἰδίοις πράγμασιν ἀδικοῦντας καὶ τοὺς μὴ δικαίως ἐγκαλοῦντας" </skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_judges_suits_for_intentional_homicide_intentional_wounding_and_destruction_of_sacred_olive_trees_that_investigates_reports_of_treason_made_up_of_all_former_archons_becomes_a_member_after_archonship_serves_for_the_remainder_of_life">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Council of the Areopagus</rdfs:label>
        <skos:prefLabel xml:lang="en">Council of the Areopagus</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that judges suits for intentional homicide intentional wounding and destruction of sacred olive trees, that investigates reports of treason, made up of all former archons, becomes a member after archonship, serves for the remainder of life.</skos:definition>
        <rdfs:label xml:lang="grc">βουλὴ ἐξ Ἀρείου πάγου</rdfs:label>
        <skos:prefLabel xml:lang="grc">βουλὴ ἐξ Ἀρείου πάγου</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that judges suits for intentional homicide intentional wounding and destruction of sacred olive trees, that investigates reports of treason, made up of all former archons, becomes a member after archonship, serves for the remainder of life.</skos:definition>
        <skos:example xml:lang="grc">Dem. 18.133: "καὶ εἰ μὴ ἡ βουλὴ ἡ ἐξ Ἀρείου πάγου τὸ πρᾶγμ᾽ αἰσθομένη καὶ τὴν ὑμετέραν ἄγνοιαν ἐν οὐ δέοντι συμβεβηκυῖαν ἰδοῦσα ἐπεζήτησε τὸν ἄνθρωπον καὶ συλλαβοῦσ᾽ ἐπανήγαγεν ὡς ὑμᾶς, ἐξήρπαστ᾽ ἂν ὁ τοιοῦτος καὶ τὸ δίκην δοῦναι διαδὺς ἐξεπέπεμπτ᾽ ἂν ὑπὸ τοῦ σεμνολόγου τουτουί:." </skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_family_law_for_metics_held_by_one_person">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Polemarch</rdfs:label>
        <skos:prefLabel xml:lang="en">Polemarch</skos:prefLabel>
        <skos:definition xml:lang="en">Archon that supervises family law for metics, held by one person.</skos:definition>
        <rdfs:label xml:lang="grc">πολέμαρχος</rdfs:label>
        <skos:prefLabel xml:lang="grc">πολέμαρχος</skos:prefLabel>
        <skos:definition xml:lang="grc">ἄρχων that supervises family law for metics, held by one person.</skos:definition>
        <skos:example xml:lang="grc">Dem. 59.40: "ἀφαιρουμένου δὲ τοῦ Στεφάνου κατὰ τὸν νόμον εἰς ἐλευθερίαν, κατηγγύησεν αὐτὴν πρὸς τῷ πολεμάρχῳ."</skos:example>
        <skos:broader rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_prosecutes_euthanai_brought_forward_by_logistai_held_by_10_people_chosen_by_lot_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Public advocates</rdfs:label>
        <skos:prefLabel xml:lang="en">Public advocates</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that prosecutes euthanai brought forward by logistai, held by 10 people, chosen by lot, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">συνήγοροι</rdfs:label>
        <skos:prefLabel xml:lang="grc">συνήγοροι</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that prosecutes euthanai brought forward by logistai, held by 10 people, chosen by lot, serves a one year term.</skos:definition>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_family_lawsuits_for_citizens_held_by_one_person">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Eponymous Archon</rdfs:label>
        <skos:prefLabel xml:lang="en">Eponymous Archon</skos:prefLabel>
        <skos:definition xml:lang="en">Archon that supervises family lawsuits for citizens, held by one person.</skos:definition>
        <rdfs:label xml:lang="grc">ἐπώνυμος ἄρχων</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἐπώνυμος ἄρχων</skos:prefLabel>
        <skos:definition xml:lang="grc">ἄρχων that supervises family lawsuits for citizens, held by one person.</skos:definition>
        <skos:example xml:lang="grc">Dem. 21.9: "ἐν δὲ ταύτῃ ἐπειδὰν χρηματίσωσιν οἱ πρόεδροι περὶ ὧν διῴκηκεν ὁ ἄρχων, χρηματίζειν καὶ περὶ ὧν ἄν τις ἠδικηκὼς ᾖ περὶ τὴν ἑορτὴν ἢ παρανενομηκώς"</skos:example>
        <skos:broader rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_arbitrates_private_cases_concerning_more_than_ten_drachmas_made_up_of_all_eligible_citizens_over_59_from_all_male_citizens_over_59_serves_for_the_remainder_of_life">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Arbitrators</rdfs:label>
        <skos:prefLabel xml:lang="en">Arbitrators</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that arbitrates private cases concerning more than ten drachmas, made up of all eligible citizens over 59, from all male citizens over 59, serves for the remainder of life.</skos:definition>
        <rdfs:label xml:lang="grc">διαιτηταί</rdfs:label>
        <skos:prefLabel xml:lang="grc">διαιτηταί</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that arbitrates private cases concerning more than ten drachmas, made up of all eligible citizens over 59, from all male citizens over 59, serves for the remainder of life.</skos:definition>
        <skos:broader rdf:resource="#Legal_Body"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q64224327"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_judges_the_majority_of_legal_proceedings_has_a_size_that_varies_based_on_case_selected_from_a_pool_of_6000_chosen_by_lot_from_male_citizens_over_30_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Law courts</rdfs:label>
        <skos:prefLabel xml:lang="en">Law courts</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that judges the majority of legal proceedings, has a size that varies based on case, chosen by lot, from male citizens over 30, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="en">Dikasterion</rdfs:label>
        <rdfs:label xml:lang="grc">δικαστήριον</rdfs:label>
        <skos:prefLabel xml:lang="grc">δικαστήριον</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that judges the majority of legal proceedings, has a size that varies based on case selected from a pool of 6000, chosen by lot, from male citizens over 30, serves a one year term.</skos:definition>
        <skos:example xml:lang="grc">Dem. 21.221: "αὐτίκα δὴ μάλα, ἐπειδὰν ἀναστῇ τὸ δικαστήριον, εἷς ἕκαστος ὑμῶν"</skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_judges_presentations_that_deliberates_over_political_issues_made_up_of_all_adult_male_citizens">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Assembly</rdfs:label>
        <skos:prefLabel xml:lang="en">Assembly</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that judges presentations, that deliberates over political issues, made up of all adult male citizens.</skos:definition>
        <rdfs:label xml:lang="en">Ekklesia</rdfs:label>
        <skos:altLabel xml:lang="en">Ekklesia</skos:altLabel>
        <skos:definition xml:lang="en">Legal Body that judges presentations, that deliberates over political issues, made up of all adult male citizens.</skos:definition>
        <rdfs:label xml:lang="grc">ἐκκλησία</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἐκκλησία</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that judges presentations, that deliberates over political issues, made up of all adult male citizens.</skos:definition>
        <skos:example xml:lang="grc">Dem. 25.9:  καὶ τὰ μὲν ἄλλ᾽ ἐάσω: ἀλλ᾽ εἰς τὰς ἐκκλησίας ἀναβαίνουσιν, ἐν αἷς ὑμεῖς γνώμης ἀπόδειξιν, οὐ πονηρίας τοῖς λέγουσι προτίθετε, τόλμαν καὶ κραυγὴν καὶ ψευδεῖς αἰτίας καὶ συκοφαντίαν καὶ ἀναισχυντίαν καὶ πάντα τὰ τοιαῦτα συνεσκευασμένοι, ὧν οὐκ ἂν εὕροι τις ἐναντιώτερα τῷ βουλεύεσθαι, νομίζω δ᾽ οὐδ᾽ ἂν αἰσχίω."</skos:example>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_supervises_euthanai_initiated_by_public_held_by_10_people_chosen_by_lot_serves_a_one_year_term">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Special auditors</rdfs:label>
        <skos:prefLabel xml:lang="en">Special auditors</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that supervises euthanai initiated by public, held by 10 people, chosen by lot, serves a one year term.</skos:definition>
        <rdfs:label xml:lang="grc">εὔθυνοι</rdfs:label>
        <skos:prefLabel xml:lang="grc">εὔθυνοι</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that supervises euthanai initiated by public, held by 10 people, chosen by lot, serves a one year term.</skos:definition>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term_that_supervises_religious_suits_such_as_impiety_indictments_and_homicide_suits_held_by_one_person">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Basileus</rdfs:label>
        <skos:prefLabel xml:lang="en">Basileus</skos:prefLabel>
        <skos:definition xml:lang="en">Archon that supervises religious suits such as impiety indictments and homicide suits, held by one person.</skos:definition>
        <rdfs:label xml:lang="en">King</rdfs:label>
        <skos:altLabel xml:lang="en">King</skos:altLabel>
        <skos:definition xml:lang="en">Archon that supervises religious suits such as impiety indictments and homicide suits, held by one person.</skos:definition>
        <rdfs:label xml:lang="grc">βασιλεὺς</rdfs:label>
        <skos:prefLabel xml:lang="grc">βασιλεὺς</skos:prefLabel>
        <skos:definition xml:lang="grc">ἄρχων that supervises religious suits such as impiety indictments and homicide suits, held by one person.</skos:definition>
        <skos:example xml:lang="grc">Lys. 6.4: " ἐὰν νυνὶ Ἀνδοκίδης ἀθῷος ἀπαλλαγῇ δι᾽ ὑμᾶς ἐκ τοῦδε τοῦ ἀγῶνος καὶ ἔλθῃ κληρωσόμενος τῶν ἐννέα ἀρχόντων καὶ λάχῃ βασιλεύς, ἄλλο τι ἢ ὑπὲρ ὑμῶν καὶ θυσίας θύσει καὶ εὐχὰς εὔξεται κατὰ τὰ πάτρια"</skos:example>
        <skos:broader rdf:resource="#Legal_Body_that_holds_preliminary_hearings_and_schedule_cases_chosen_by_lot_serves_a_one_year_term"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Body_that_examines_the_financial_records_of_magistrates_that_supervises_euthanai_for_embezzlement_and_bribes_held_by_10_people_elected_from_Council_of_500_serves_for_one_tenth_of_a_year">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_bodies"/>
        <rdfs:label xml:lang="en">Auditors</rdfs:label>
        <skos:prefLabel xml:lang="en">Auditors</skos:prefLabel>
        <skos:definition xml:lang="en">Legal Body that examines the financial records of magistrates, that supervises euthanai for embezzlement and bribes, held by 10 people, elected from Council of 500, serves for one tenth of a year.</skos:definition>
        <rdfs:label xml:lang="en">Logistai</rdfs:label>
        <skos:altLabel xml:lang="en">Logistai</skos:altLabel>
        <skos:definition xml:lang="en">Legal Body that examines the financial records of magistrates, that supervises euthanai for embezzlement and bribes, held by 10 people, elected from Council of 500, serves for one tenth of a year.</skos:definition>
        <rdfs:label xml:lang="grc">λογισταί</rdfs:label>
        <skos:prefLabel xml:lang="grc">λογισταί</skos:prefLabel>
        <skos:definition xml:lang="grc">Τέλος that examines the financial records of magistrates, that supervises euthanai for embezzlement and bribes, held by 10 people, elected from Council of 500, serves for one tenth of a year.</skos:definition>
        <skos:broader rdf:resource="#Legal_Body"/>
    </skos:Concept>

