        <owl:disjointWith rdf:resource="#Legal_Body_that_supervises_euthanai_initiated_by_public_held_by_10_people_chosen_by_lot_serves_a_one_year_term"/>
        <owl:disjointWith rdf:resource="#Legal_Body_that_judges_unintentional_and_justifiable_homicide_cases_has_51_members_selected_from_Council_of_Areopagus_serves_a_one_year_term"/>
        <owl:disjointWith rdf:resource="#Legal_Body_that_judges_presentations_that_deliberates_over_political_issues_made_up_of_all_adult_male_citizens"/>
