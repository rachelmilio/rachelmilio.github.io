	<!--  SKOS Concept Scheme -->

    <skos:ConceptScheme rdf:about="http://www.ontologia.fr/OTB/classical_orators">
        <dc:title>Classical-Orators</dc:title>
        <dc:description>This is version 1.2 of a dataset created in the context of a PhD thesis in "Semantic Annotation and Attic Oratory" that defines the corpus of Attic Oratory spanning from the birth of Antiphon in 480 BC to the death of Dinarchus in 292 BC. This work draws from the Loeb Classical Library and the Perseus Project. The terms and concepts for the corpus of speeches draws on the classifications defined in Aristotle's Rhetoric. </dc:description>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-04</dc:issued>
        <dc:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-10-10</dc:modified>
        <dc:creator>Rachel Milio</dc:creator>
        <dc:publisher>University of Crete</dc:publisher>
    </skos:ConceptScheme>

	<!--  SKOS Concepts -->

    <skos:Concept rdf:about="#Person_who_writes_prose_writes_speeches_for_others_to_deliver">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">logographer</rdfs:label>
        <skos:prefLabel xml:lang="en">logographer</skos:prefLabel>
        <skos:definition xml:lang="en">Author writes speeches for others to deliver.</skos:definition>
        <rdfs:label xml:lang="grc">λογογράφος</rdfs:label>
        <skos:prefLabel xml:lang="grc">λογογράφος</skos:prefLabel>
        <skos:definition xml:lang="grc">Συγγραφεύς writes speeches for others to deliver.</skos:definition>
        <skos:broader rdf:resource="#Person_who_writes_prose"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Person_who_writes_prose">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">author</rdfs:label>
        <skos:prefLabel xml:lang="en">author</skos:prefLabel>
        <skos:definition xml:lang="en">Person who writes prose.</skos:definition>
        <rdfs:label xml:lang="grc">συγγραφεύς</rdfs:label>
        <skos:prefLabel xml:lang="grc">συγγραφεύς</skos:prefLabel>
        <skos:definition xml:lang="grc">ἄνθρωπος who writes prose.</skos:definition>
        <skos:broader rdf:resource="#Person"/>
        <skos:narrower rdf:resource="#Person_who_writes_prose_writes_speeches_to_deliver_in_court"/>
        <skos:narrower rdf:resource="#Person_who_writes_prose_writes_speeches_for_others_to_deliver"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Speech">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <skos:topConceptOf rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">rhetorical speech</rdfs:label>
        <skos:prefLabel xml:lang="en">rhetorical speech</skos:prefLabel>
        <skos:definition xml:lang="en"> is a written work delivered orally.</skos:definition>
        <rdfs:label xml:lang="grc">ῥητορικός λόγος</rdfs:label>
        <skos:prefLabel xml:lang="grc">ῥητορικός λόγος</skos:prefLabel>
        <skos:definition xml:lang="grc"> is a written work delivered orally.</skos:definition>
        <skos:narrower rdf:resource="#Speech_addressed_to_judges_about_the_past_with_the_end_of_the_just_or_the_unjust"/>
        <skos:narrower rdf:resource="#Speech_addressed_to_judges_about_the_future_with_the_end_of_the_expedient_or_harmful"/>
        <skos:narrower rdf:resource="#Speech_addressed_to_mere_spectators_about_the_present_with_the_end_of_the_honorable_or_the_disgraceful"/>
        <skos:related rdf:resource="#Person"/>
        <skos:broadMatch rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E33_Linguistic_Object"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Person_who_writes_prose_writes_speeches_to_deliver_in_court">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">orator</rdfs:label>
        <skos:prefLabel xml:lang="en">orator</skos:prefLabel>
        <skos:definition xml:lang="en">Author writes speeches to deliver in court.</skos:definition>
        <rdfs:label xml:lang="en">politician</rdfs:label>
        <skos:definition xml:lang="en">Author writes speeches to deliver in court.</skos:definition>
        <rdfs:label xml:lang="grc">ῥήτωρ</rdfs:label>
        <skos:prefLabel xml:lang="grc">ῥήτωρ</skos:prefLabel>
        <skos:definition xml:lang="grc">Συγγραφεύς writes speeches to deliver in court.</skos:definition>
        <skos:broader rdf:resource="#Person_who_writes_prose"/>
        <owl:sameAs rdf:resource="https://de.wikisource.org/wiki/RE:%E1%BF%AC%CE%AE%CF%84%CF%89%CF%81"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Speech_addressed_to_judges_about_the_past_with_the_end_of_the_just_or_the_unjust">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">forensic speech</rdfs:label>
        <skos:prefLabel xml:lang="en">forensic speech</skos:prefLabel>
        <skos:definition xml:lang="en">Rhetorical speech addressed to judges, about the past, with the end of the just or the unjust.</skos:definition>
        <rdfs:label xml:lang="grc">δικανικός λόγος</rdfs:label>
        <skos:prefLabel xml:lang="grc">δικανικός λόγος</skos:prefLabel>
        <skos:definition xml:lang="grc">ῥητορικός λόγος addressed to judges, about the past, with the end of the just or the unjust.</skos:definition>
        <skos:broader rdf:resource="#Speech"/>
        <skos:narrower rdf:resource="#Speech_addressed_to_judges_about_the_past_with_the_end_of_the_just_or_the_unjust_defensive"/>
        <skos:narrower rdf:resource="#Speech_addressed_to_judges_about_the_past_with_the_end_of_the_just_or_the_unjust_accusatory"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Speech_addressed_to_judges_about_the_past_with_the_end_of_the_just_or_the_unjust_accusatory">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">forensic accusatory speech</rdfs:label>
        <skos:prefLabel xml:lang="en">forensic accusatory speech</skos:prefLabel>
        <skos:definition xml:lang="en">Forensic speech accusatory.</skos:definition>
        <rdfs:label xml:lang="grc">δικανικός λόγος κατηγορία</rdfs:label>
        <skos:prefLabel xml:lang="grc">δικανικός λόγος κατηγορία</skos:prefLabel>
        <skos:definition xml:lang="grc">Δικανικός λόγος accusatory.</skos:definition>
        <skos:broader rdf:resource="#Speech_addressed_to_judges_about_the_past_with_the_end_of_the_just_or_the_unjust"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Speech_addressed_to_judges_about_the_future_with_the_end_of_the_expedient_or_harmful">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">deliberative speech</rdfs:label>
        <skos:prefLabel xml:lang="en">deliberative speech</skos:prefLabel>
        <skos:definition xml:lang="en">Rhetorical speech addressed to judges, about the future, with the end of the expedient or harmful.</skos:definition>
        <rdfs:label xml:lang="grc">συμβουλευτικός λόγος</rdfs:label>
        <skos:prefLabel xml:lang="grc">συμβουλευτικός λόγος</skos:prefLabel>
        <skos:definition xml:lang="grc">ῥητορικός λόγος addressed to judges, about the future, with the end of the expedient or harmful.</skos:definition>
        <skos:broader rdf:resource="#Speech"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Speech_addressed_to_judges_about_the_past_with_the_end_of_the_just_or_the_unjust_defensive">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">forensic defense speech</rdfs:label>
        <skos:prefLabel xml:lang="en">forensic defense speech</skos:prefLabel>
        <skos:definition xml:lang="en">Forensic speech defensive.</skos:definition>
        <rdfs:label xml:lang="grc">δικανικός λόγος ἀπολογία</rdfs:label>
        <skos:prefLabel xml:lang="grc">δικανικός λόγος ἀπολογία</skos:prefLabel>
        <skos:definition xml:lang="grc">Δικανικός λόγος defensive.</skos:definition>
        <skos:broader rdf:resource="#Speech_addressed_to_judges_about_the_past_with_the_end_of_the_just_or_the_unjust"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Person">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <skos:topConceptOf rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">person</rdfs:label>
        <skos:prefLabel xml:lang="en">person</skos:prefLabel>
        <skos:definition xml:lang="en"> is a human being.</skos:definition>
        <rdfs:label xml:lang="grc">ἄνθρωπος</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἄνθρωπος</skos:prefLabel>
        <skos:definition xml:lang="grc"> is a human being.</skos:definition>
        <skos:narrower rdf:resource="#Person_who_writes_prose"/>
        <owl:sameAs rdf:resource="http://xmlns.com/foaf/spec/#term_Person"/>
        <owl:sameAs rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E21_Person"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Speech_addressed_to_mere_spectators_about_the_present_with_the_end_of_the_honorable_or_the_disgraceful">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/classical_orators"/>
        <rdfs:label xml:lang="en">epideictic speech</rdfs:label>
        <skos:prefLabel xml:lang="en">epideictic speech</skos:prefLabel>
        <skos:definition xml:lang="en">Rhetorical speech addressed to mere spectators, about the present, with the end of the honorable or the disgraceful.</skos:definition>
        <rdfs:label xml:lang="grc">ἐπιδεικτικός λόγος</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἐπιδεικτικός λόγος</skos:prefLabel>
        <skos:definition xml:lang="grc">ῥητορικός λόγος addressed to mere spectators, about the present, with the end of the honorable or the disgraceful.</skos:definition>
        <skos:broader rdf:resource="#Speech"/>
    </skos:Concept>

