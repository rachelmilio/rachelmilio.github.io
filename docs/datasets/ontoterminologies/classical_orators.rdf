    <ontolex:LexicalEntry rdf:about="#deliberative_speech_en">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_deliberative_speech_en">
                <ontolex:writtenRep xml:lang="en">deliberative speech</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_deliberative_speech_en">
                <ontolex:isEvokedBy rdf:resource="#deliberative_speech_en"/>
                <skos:definition xml:lang="en">Rhetorical speech addressed to judges, about the future, with the end of the expedient or harmful.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Speech_addressed_to_judges_about_the_future_with_the_end_of_the_expedient_or_harmful"/>
