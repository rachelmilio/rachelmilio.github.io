	<!--  OWL Classes -->

    <owl:Class rdf:about="#Person_who_writes_prose_writes_speeches_for_others_to_deliver">
        <rdfs:label xml:lang="en">logographer</rdfs:label>
        <skos:prefLabel xml:lang="en">logographer</skos:prefLabel>
        <skos:definition xml:lang="en">Author writes speeches for others to deliver.</skos:definition>
        <rdfs:label xml:lang="grc">λογογράφος</rdfs:label>
        <skos:prefLabel xml:lang="grc">λογογράφος</skos:prefLabel>
        <skos:definition xml:lang="grc">Συγγραφεύς writes speeches for others to deliver.</skos:definition>
        <rdfs:subClassOf rdf:resource="#Person_who_writes_prose"/>
        <owl:disjointWith rdf:resource="#Person_who_writes_prose_writes_speeches_to_deliver_in_court"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#writes_speeches_for_others_to_deliver"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#Person_who_writes_prose">
        <rdfs:label xml:lang="en">author</rdfs:label>
        <skos:prefLabel xml:lang="en">author</skos:prefLabel>
        <skos:definition xml:lang="en">Person who writes prose.</skos:definition>
        <rdfs:label xml:lang="grc">συγγραφεύς</rdfs:label>
        <skos:prefLabel xml:lang="grc">συγγραφεύς</skos:prefLabel>
        <skos:definition xml:lang="grc">ἄνθρωπος who writes prose.</skos:definition>
        <rdfs:subClassOf rdf:resource="#Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#who_writes_prose"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#Speech">
        <rdfs:label xml:lang="en">rhetorical speech</rdfs:label>
        <skos:prefLabel xml:lang="en">rhetorical speech</skos:prefLabel>
        <skos:definition xml:lang="en"> is a written work delivered orally.</skos:definition>
        <rdfs:label xml:lang="grc">ῥητορικός λόγος</rdfs:label>
        <skos:prefLabel xml:lang="grc">ῥητορικός λόγος</skos:prefLabel>
        <skos:definition xml:lang="grc"> is a written work delivered orally.</skos:definition>
        <owl:disjointWith rdf:resource="#Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#is_a_written_work_delivered_orally"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasAuthor"/>
                <owl:someValuesFrom rdf:resource="#Person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasYearOfWriting"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#perseusIdentifier"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
