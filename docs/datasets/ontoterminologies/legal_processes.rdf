        <owl:disjointWith rdf:resource="#Legal_Stage_for_litigants_to_propose_penalties_for_convicted_defendant_before_the_dikasterion_in_assessable_lawsuits"/>
        <owl:disjointWith rdf:resource="#Legal_Stage_for_litigants_to_introduce_their_claims_and_evidence_and_be_questioned_before_the_appropriate_magistrate_in_homicide_suits"/>
