    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_intentional_wounding_with_a_weapon_supervised_by_Basileus_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_exile_and_confiscation_with_non-assessable_penalty">
        <rdfs:label xml:lang="en">intentional wounding suit</rdfs:label>
        <skos:prefLabel xml:lang="en">intentional wounding suit</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for intentional wounding with a weapon, supervised by Basileus, tried by the Council of the Areopagus, has punishment for convicted of exile and confiscation, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">τραύματος ἐκ προνοίας γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">τραύματος ἐκ προνοίας γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for intentional wounding with a weapon, supervised by Basileus, tried by the Council of the Areopagus, has punishment for convicted of exile and confiscation, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem 23.22: "δικάζειν δὲ τὴν βουλὴν τὴν ἐν Ἀρείῳ πάγῳ φόνου καὶ τραύματος ἐκ προνοίας καὶ πυρκαϊᾶς καὶ φαρμάκων, ἐάν τις ἀποκτείνῃ δούς."</skos:example>
