    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_conspiracy_and_bribery_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_ten_times_fine_and_hereditary_disenfranchisement_with_non-assessable_penalty">
        <rdfs:label xml:lang="en">indictment for accepting bribes</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for accepting bribes</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for conspiracy and bribery, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a ten times fine and hereditary disenfranchisement, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">δώρων γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">δώρων γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for conspiracy and bribery, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a ten times fine and hereditary disenfranchisement, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 2.3: "ἀλλ᾽ οἶμαι Δημοσθένης οὐ χαίρει δικαίοις λόγοις, οὐδ᾽ οὕτω παρεσκεύασται, ἀλλὰ τὴν ὑμετέραν ὀργὴν ἐκκαλέσασθαι βεβούληται. καὶ κατηγόρηκε δωροδοκίας, ἀπίθανος ὢν πρὸς τὴν ὑποψίαν ταύτην: τὸν γὰρ ἐπὶ ταῖς δωροδοκίαις προτρεπόμενον ὀργίζεσθαι, αὐτὸν χρὴ τῶν τοιούτων ἔργων ἀπέχεσθαι."</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_crimes_of_hubris_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_impiety_supervised_by_Basileus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_with_assessable_penalty_through_timesis"/>
