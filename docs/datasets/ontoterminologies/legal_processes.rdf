    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_claim_full_amount_of_a_dowry_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <rdfs:label xml:lang="en">suit for a dowry</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for a dowry</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit to claim full amount of a dowry, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">δίκη προικός</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκη προικός</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι to claim full amount of a dowry, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Isaeus 3.9: "ἢ εἰ μὴ ἐκομίζετο, ὁποίαν δίκην σίτου ἢ τῆς προικὸς αὐτῆς ἐν εἴκοσιν ἔτεσι τῷ ἔχοντι τὸν κλῆρον δικάσασθαι ἠξίωσεν,1 ἢ εἴ του ἀνθρώπων ἐναντίον προσῆλθεν ἐγκαλῶν τῷ κληρονόμῳ περὶ τῆς προικὸς τῆς ἀδελφῆς ἐν χρόνῳ τοσούτῳ. περί τε οὖν τούτων ἡδέως ἂν πυθοίμην, ὅ τι ποτ᾽ ἦν τὸ αἴτιον τοῦ μηδὲν τούτων γεγενῆσθαι περὶ τῆς ἐγγυητῆς （ὡς μεμαρτύρηκεν οὗτος） γυναικός,"</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_physically_obstructing_prosecutor_from_inheritance_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_restore_property_to_prosecutor_and_pay_cash_value_to_state_has_penalty_of_epobelia_for_failed_prosecution_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_block_an_illegal_prosecution_initiated_by_defendant_at_anakrisis_supervised_by_Archon_from_initial_case_tried_by_the_dikasterion_has_punishment_for_convicted_of_one-sixth_the_sum_in_question_and_ends_litigation__has_penalty_of_epobelia_for_failed_prosecution_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_illegal_defamatory_speech_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_fixed_fine_has_penalty_of_epobelia_for_failed_prosecution_with_non-assessable_penalty"/>
