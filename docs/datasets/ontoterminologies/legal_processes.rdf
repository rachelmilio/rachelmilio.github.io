                <ontolex:isEvokedBy rdf:resource="#μοιχείας γραφή_grc"/>
                <skos:definition xml:lang="grc">Γραφή for illicit consensual sex with a woman, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_illicit_consensual_sex_with_a_woman_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#φόνος_δίκη_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_φόνος_δίκη_grc">
                <ontolex:writtenRep xml:lang="grc">φόνος δίκη</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_φόνος_δίκη_grc">
                <ontolex:isEvokedBy rdf:resource="#φόνος_δίκη_grc"/>
                <skos:definition xml:lang="grc">Δίκη brought forward by relatives of victim, defendant summoned by proclamation at funeral of victim, initiated with a proclamation at funeral of victim, supervised by Basileus, with a prosecutor and defendant, has no penalty for failed prosecution, with non-assessable penalty.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#φόνος ἑκούσιος_δίκη_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_φόνος ἑκούσιος_δίκη_grc">
                <ontolex:writtenRep xml:lang="grc">φόνος ἑκούσιος δίκη</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_φόνος ἑκούσιος_δίκη_grc">
                <ontolex:isEvokedBy rdf:resource="#φόνος ἑκούσιος_δίκη_grc"/>
                <skos:definition xml:lang="grc">Φόνος δίκη for intentional homicide, tried by the Council of the Areopagus, has punishment for convicted of death and confiscation of property.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty_for_intentional_homicide_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_death_and_confiscation_of_property"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#βιαίων δίκη_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_βιαίων δίκη_grc">
                <ontolex:writtenRep xml:lang="grc">βιαίων δίκη</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_βιαίων δίκη_grc">
                <ontolex:isEvokedBy rdf:resource="#βιαίων δίκη_grc"/>
                <skos:definition xml:lang="grc">Δίκαι ἴδιαι for violent acts including rape, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_violent_acts_including_rape_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#εὔθυναι_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_εὔθυναι_grc">
                <ontolex:writtenRep xml:lang="grc">εὔθυναι</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_εὔθυναι_grc">
                <ontolex:isEvokedBy rdf:resource="#εὔθυναι_grc"/>
                <skos:definition xml:lang="grc">Δίκαι δημόσιαι to evaluate term in office, initiated automatically after term of magistrate, supervised by Euthynoi, tried by the dikasterion, has punishment for convicted of tenfold damages, with non-assessable penalty.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_evaluate_term_in_office_initiated_automatically_after_term_of_magistrate_supervised_by_Euthynoi_tried_by_the_dikasterion_has_punishment_for_convicted_of_tenfold_damages_with_non-assessable_penalty"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#ἔνδειξις_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_ἔνδειξις_grc">
                <ontolex:writtenRep xml:lang="grc">ἔνδειξις</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_ἔνδειξις_grc">
                <ontolex:isEvokedBy rdf:resource="#ἔνδειξις_grc"/>
                <skos:definition xml:lang="grc">Δίκαι δημόσιαι for theft or murder or illegal exercise of citizen rights, defendant summoned by arrest, inititated by plaintiff denouncing defendant to a magistrate for arrest, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
