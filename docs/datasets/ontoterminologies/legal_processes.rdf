    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <rdfs:label xml:lang="en">presentation</rdfs:label>
        <skos:prefLabel xml:lang="en">presentation</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit defendant summoned by proclamation in the Assembly, initiated by vote before the Assembly, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a penal assessment, has penalty of 1000 drachmas for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">προβολή</rdfs:label>
        <skos:prefLabel xml:lang="grc">προβολή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι defendant summoned by proclamation in the Assembly, initiated by vote before the Assembly, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a penal assessment, has penalty of 1000 drachmas for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 21.193: "οἶμαι τοίνυν αὐτὸν οὐδὲ τοῦ δήμου κατηγορεῖν ὀκνήσειν οὐδὲ τῆς ἐκκλησίας, ἀλλ᾽ ἅπερ τότ᾽ ἐτόλμα λέγειν ὅτ᾽ ἦν ἡ προβολή, ταῦτα καὶ νῦν ἐρεῖν, ὡς ὅσοι δέον ἐξιέναι κατέμενον καὶ ὅσοι τὰ φρούρι᾽ ἦσαν ἔρημα λελοιπότες, ἐξεκλησίασαν, καὶ χορευταὶ καὶ ξένοι καὶ τοιοῦτοί τινες ἦσαν οἳ κατεχειροτόνησαν αὐτοῦ."</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
