        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_causing_financial_damages_related_to_mining_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_recover_a_sum_of_money_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_recover_a_deposit_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Stage_for_litigants_to_propose_penalties_for_convicted_defendant_before_the_dikasterion_in_assessable_lawsuits">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">assessment of sentence</rdfs:label>
        <skos:prefLabel xml:lang="en">assessment of sentence</skos:prefLabel>
        <skos:definition xml:lang="en">Stage of lawsuit for litigants to propose penalties for convicted defendant, before the dikasterion, in assessable lawsuits.</skos:definition>
        <rdfs:label xml:lang="en">timesis</rdfs:label>
        <skos:altLabel xml:lang="en">timesis</skos:altLabel>
        <rdfs:label xml:lang="grc">τίμησις</rdfs:label>
        <skos:prefLabel xml:lang="grc">τίμησις</skos:prefLabel>
        <skos:definition xml:lang="grc">Stage of lawsuit for litigants to propose penalties for convicted defendant, before the dikasterion, in assessable lawsuits.</skos:definition>
        <skos:broader rdf:resource="#Legal_Stage"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_claim_full_amount_of_a_dowry_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit for a dowry</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for a dowry</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit to claim full amount of a dowry, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">δίκη προικός</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκη προικός</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι to claim full amount of a dowry, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Isaeus 3.9: "ἢ εἰ μὴ ἐκομίζετο, ὁποίαν δίκην σίτου ἢ τῆς προικὸς αὐτῆς ἐν εἴκοσιν ἔτεσι τῷ ἔχοντι τὸν κλῆρον δικάσασθαι ἠξίωσεν,1 ἢ εἴ του ἀνθρώπων ἐναντίον προσῆλθεν ἐγκαλῶν τῷ κληρονόμῳ περὶ τῆς προικὸς τῆς ἀδελφῆς ἐν χρόνῳ τοσούτῳ. περί τε οὖν τούτων ἡδέως ἂν πυθοίμην, ὅ τι ποτ᾽ ἦν τὸ αἴτιον τοῦ μηδὲν τούτων γεγενῆσθαι περὶ τῆς ἐγγυητῆς （ὡς μεμαρτύρηκεν οὗτος） γυναικός,"</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_evaluate_term_in_office_initiated_automatically_after_term_of_magistrate_supervised_by_Euthynoi_tried_by_the_dikasterion_has_punishment_for_convicted_of_tenfold_damages_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">review</rdfs:label>
        <skos:prefLabel xml:lang="en">review</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit to evaluate term in office, initiated automatically after term of magistrate, supervised by Euthynoi, tried by the dikasterion, has punishment for convicted of tenfold damages, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">εὔθυναι</rdfs:label>
        <skos:prefLabel xml:lang="grc">εὔθυναι</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι to evaluate term in office, initiated automatically after term of magistrate, supervised by Euthynoi, tried by the dikasterion, has punishment for convicted of tenfold damages, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">--- new context ---
--- should contain the term ---</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Stage_for_prosecutor_to_summon_defendant_to_magistrate_before_one_or_more_kleteres_in_non_homicide_suits_where_defendant_is_not_arrested">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">oral summons</rdfs:label>
        <skos:prefLabel xml:lang="en">oral summons</skos:prefLabel>
        <skos:definition xml:lang="en">Stage of lawsuit for prosecutor to summon defendant to magistrate, before one or more kleteres, in non homicide suits where defendant is not arrested.</skos:definition>
        <rdfs:label xml:lang="en">prosklesis</rdfs:label>
        <skos:altLabel xml:lang="en">prosklesis</skos:altLabel>
        <rdfs:label xml:lang="grc">πρόσκλησις</rdfs:label>
        <skos:prefLabel xml:lang="grc">πρόσκλησις</skos:prefLabel>
        <skos:definition xml:lang="grc">Stage of lawsuit for prosecutor to summon defendant to magistrate, before one or more kleteres, in non homicide suits where defendant is not arrested.</skos:definition>
        <skos:broader rdf:resource="#Legal_Stage"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_illegally_addressing_the_Assembly_defendant_summoned_by_proclamation_in_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_disenfranchisement_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">scrutiny of speakers</rdfs:label>
        <skos:prefLabel xml:lang="en">scrutiny of speakers</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for illegally addressing the Assembly, defendant summoned by proclamation in the Assembly, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of disenfranchisement, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">δοκιμασία τῶν ῥητόρων</rdfs:label>
        <skos:prefLabel xml:lang="grc">δοκιμασία τῶν ῥητόρων</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for illegally addressing the Assembly, defendant summoned by proclamation in the Assembly, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of disenfranchisement, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q95983976"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis_for_deceiving_the_people">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">presentation against deceiving the people</rdfs:label>
        <skos:prefLabel xml:lang="en">presentation against deceiving the people</skos:prefLabel>
        <skos:definition xml:lang="en">Presentation for deceiving the people.</skos:definition>
        <rdfs:label xml:lang="grc">προβολή ἀπατήσεως τοῦ δήμου</rdfs:label>
        <skos:prefLabel xml:lang="grc">προβολή ἀπατήσεως τοῦ δήμου</skos:prefLabel>
        <skos:definition xml:lang="grc">Προβολή for deceiving the people.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_causing_financial_damages_related_to_mining_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit for mining damages</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for mining damages</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit for causing financial damages related to mining, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">δίκη μεταλλική</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκη μεταλλική</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι for causing financial damages related to mining, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

