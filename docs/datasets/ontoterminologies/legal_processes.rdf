            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_initiated_by_plaintiff_arresting_defendant_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
    </ontolex:LexicalEntry>


