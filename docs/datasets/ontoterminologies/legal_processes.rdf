            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_δώρων_γραφή_grc">
                <ontolex:isEvokedBy rdf:resource="#δώρων_γραφή_grc"/>
                <skos:definition xml:lang="grc">Γραφή for conspiracy and bribery, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a ten times fine and hereditary disenfranchisement, with non-assessable penalty.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_conspiracy_and_bribery_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_ten_times_fine_and_hereditary_disenfranchisement_with_non-assessable_penalty"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#ὕβρεως_γραφή_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_ὕβρεως_γραφή_grc">
                <ontolex:writtenRep xml:lang="grc">ὕβρεως γραφή</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_ὕβρεως_γραφή_grc">
                <ontolex:isEvokedBy rdf:resource="#ὕβρεως_γραφή_grc"/>
                <skos:definition xml:lang="grc">Γραφή for crimes of hubris, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
