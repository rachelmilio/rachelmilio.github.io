    <owl:Class rdf:about="#Legal_Stage_for_litigants_to_introduce_their_claims_and_evidence_and_be_questioned_before_the_appropriate_magistrate_in_all_suits_except_homicide_suits">
        <rdfs:label xml:lang="en">preliminary hearing</rdfs:label>
