            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
    </ontolex:LexicalEntry>

