    <owl:Class rdf:about="#Legal_proceeding_with_assessable_penalty_through_timesis">
        <rdfs:label xml:lang="en">assessable lawsuit</rdfs:label>
        <skos:prefLabel xml:lang="en">assessable lawsuit</skos:prefLabel>
        <skos:definition xml:lang="en">Lawsuit with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">δίκη τιμητή</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκη τιμητή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκη with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 27.67: "καὶ νῦν κομίσασθαι τἀμαυτοῦ ζητῶν εἰς κίνδυνον καθέστηκα τὸν μέγιστον. ἂν γὰρ ἀποφύγῃ μ᾽ οὗτος, ὃ μὴ γένοιτο, τὴν ἐπωβελίαν ὀφλήσω μνᾶς ἑκατόν. καὶ τούτῳ μέν, ἐὰν καταψηφίσησθε, τιμητόν, κοὐκ ἐκ τῶν ἑαυτοῦ χρημάτων, ἀλλ᾽ ἐκ τῶν ἐμῶν ποιήσεται τὴν ἔκτεισιν: ἐμοὶ δ᾽ ἀτίμητον τοῦτ᾽ ἔστιν, ὥστ᾽ οὐ μόνον ἔσομαι τῶν πατρῴων ἀπεστερημένος, ἀλλὰ καὶ πρὸς ἠτιμωμένος, ἂν μὴ νῦν ἡμᾶς ὑμεῖς ἐλεήσητε."</skos:example>
        <rdfs:label xml:lang="grc">ἀγών τιμητός</rdfs:label>
        <skos:altLabel xml:lang="grc">ἀγών τιμητός</skos:altLabel>
        <skos:definition xml:lang="grc">A δίκη with an assessable penalty through τίμησις.</skos:definition>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_non-assessable_penalty_has_punishment_for_convicted_of_death_has_no_penalty_for_failed_prosecution"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_initiated_by_plaintiff_arresting_defendant_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_physically_obstructing_prosecutor_from_inheritance_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_restore_property_to_prosecutor_and_pay_cash_value_to_state_has_penalty_of_epobelia_for_failed_prosecution_with_non-assessable_penalty"/>
