    <owl:DatatypeProperty rdf:about="#date">
        <rdfs:label>date</rdfs:label>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Legal_proceeding"/>
                </owl:unionOf>
