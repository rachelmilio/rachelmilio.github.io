                <ontolex:isEvokedBy rdf:resource="#δοκιμασία_ἀδύνατοι_grc"/>
                <skos:definition xml:lang="grc">Δίκαι δημόσιαι to examine disabled pension recipient, tried by the Council, has punishment for convicted of losing pension.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_examine_disabled_pension_recipient_tried_by_the_Council_has_punishment_for_convicted_of_losing_pension"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#παραγραφή_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_παραγραφή_grc">
                <ontolex:writtenRep xml:lang="grc">παραγραφή</ontolex:writtenRep>
            </ontolex:Form>
