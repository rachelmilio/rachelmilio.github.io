    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_destruction_of_sacred_olive_trees_supervised_by_Basileus_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_death_with_non-assessable_penalty">
        <rdfs:label xml:lang="en">indictment for removal of sacred olive tree</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for removal of sacred olive tree</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for destruction of sacred olive trees, supervised by Basileus, tried by the Council of the Areopagus, has punishment for convicted of death, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἀσεβείας τοῦ σηκοῦ γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀσεβείας τοῦ σηκοῦ γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for destruction of sacred olive trees, supervised by Basileus, tried by the Council of the Areopagus, has punishment for convicted of death, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Lys. 7.2: "οὕτω δ᾽ ἄπορος ὁ ἀγών μοι καθέστηκεν, ὥστε ἀπεγράφην τὸ μὲν πρῶτον ἐλάαν ἐκ τῆς γῆς ἀφανίζειν, καὶ πρὸς τοὺς ἐωνημένους τοὺς καρποὺς τῶν μορίων πυνθανόμενοι προσῇσαν: ἐπειδὴ δ᾽ ἐκ τούτου τοῦ τρόπου ἀδικοῦντά με οὐδὲν εὑρεῖν ἐδυνήθησαν, νυνί με σηκόν φασιν1 ἀφανίζειν, ἡγούμενοι ἐμοὶ μὲν ταύτην τὴν αἰτίαν ἀπορωτάτην εἶναι ἀπελέγξαι,2 αὐτοῖς δὲ ἐξεῖναι μᾶλλον ὅ τι ἂν βούλωνται λέγειν."</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_crimes_of_hubris_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_impiety_supervised_by_Basileus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_with_assessable_penalty_through_timesis"/>
