    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">private lawsuit</rdfs:label>
        <skos:prefLabel xml:lang="en">private lawsuit</skos:prefLabel>
        <skos:definition xml:lang="en">Lawsuit brought forward by the injured party or a guardian, with a prosecutor and defendant.</skos:definition>
        <rdfs:label xml:lang="grc">δίκαι ἴδιαι</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκαι ἴδιαι</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκη brought forward by the injured party or a guardian, with a prosecutor and defendant.</skos:definition>
        <skos:example xml:lang="grc">Andoc. 1.9: " ὁρῶν ὑμᾶς καὶ ἐν τοῖς ἰδίοις καὶ ἐν τοῖς δημοσίοις περὶ πλείστου τοῦτο ποιουμένους"</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_starting_a_physical_fight_without_justification_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
