        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_παραγραφή_grc">
                <ontolex:isEvokedBy rdf:resource="#παραγραφή_grc"/>
                <skos:definition xml:lang="grc">Δίκαι ἴδιαι to block an illegal prosecution, initiated by defendant at anakrisis, supervised by Archon from initial case, tried by the dikasterion, has punishment for convicted of one-sixth the sum in question and ends litigation , has penalty of epobelia for failed prosecution, with non-assessable penalty.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_block_an_illegal_prosecution_initiated_by_defendant_at_anakrisis_supervised_by_Archon_from_initial_case_tried_by_the_dikasterion_has_punishment_for_convicted_of_one-sixth_the_sum_in_question_and_ends_litigation__has_penalty_of_epobelia_for_failed_prosecution_with_non-assessable_penalty"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#ἀγών_τιμητός_grc">
