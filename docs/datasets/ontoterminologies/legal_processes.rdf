    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_withholding_property_from_the_state_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_an_inventory_of_owed_property_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_confiscation_of_owed_property_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty">
        <rdfs:label xml:lang="en">indictment for confiscation</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for confiscation</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for withholding property from the state, defendant summoned by plaintiff via prosklesis, initiated by submitting an inventory of owed property, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of confiscation of owed property, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἀπογραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀπογραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for withholding property from the state, defendant summoned by plaintiff via prosklesis, initiated by submitting an inventory of owed property, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of confiscation of owed property, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 53.3: "εἰ μὲν οὖν μοι ἦν ἱκανὸν τὸ ὕδωρ διηγήσασθαι πρὸς ὑμᾶς τὰ ἐξ ἀρχῆς, ὅσ᾽ ἀγαθὰ πεπονθότες ὑπ᾽ ἐμοῦ οἷά με εἰργασμένοι εἰσίν, εὖ οἶδ᾽ ὅτι ὑμεῖς τ᾽ ἄν μοι ἔτι μᾶλλον συγγνώμην εἴχετε τοῦ ὀργίζεσθαι αὐτοῖς, τούτους τ᾽ ἀνοσιωτάτους ἀνθρώπων ἡγήσασθε εἶναι: νῦν δ᾽ οὐδὲ διπλάσιόν μοι τούτου ὕδωρ ἱκανὸν ἂν γένοιτο. τὰ μὲν οὖν μέγιστα καὶ περιφανῆ τῶν ἀδικημάτων, καὶ ὁπόθεν ἡ ἀπογραφὴ αὕτη γέγονεν, ἐρῶ πρὸς ὑμᾶς, τὰ δὲ πολλὰ ἐάσω."</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_initiated_by_investigation_by_the_Council_of_the_Areopagus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_maltreatment_of_parents_orphans_and_heiresses_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
