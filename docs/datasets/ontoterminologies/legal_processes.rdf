    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_initiated_by_plaintiff_arresting_defendant_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty">
        <rdfs:label xml:lang="en">summary arrest</rdfs:label>
        <skos:prefLabel xml:lang="en">summary arrest</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for theft or murder or illegal exercise of citizen rights, defendant summoned by arrest, initiated by plaintiff arresting defendant, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἀπαγωγή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀπαγωγή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for theft, murder, or illegal exercise of citizen rights, in which the defendant is summoned by arrest, initiated by plaintiff arresting defendant, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 24.146: "ὡς δὲ σαφῶς γνώσεσθ᾽ ὅτι ἀληθῆ λέγω, ἐγὼ ὑμῖν ἐρῶ. οὔτε γὰρ ἄν, ὦ ἄνδρες δικασταί, τιμᾶν ἐξῆν ὑμῖν ὅ τι χρὴ παθεῖν ἢ ἀποτεῖσαι （ἐν γὰρ τῷ παθεῖν καὶ ὁ δεσμὸς ἔνι: οὐκ ἂν οὖν ἐξῆν δεσμοῦ τιμῆσαι）, οὔθ᾽ ὅσων ἔνδειξίς ἐστιν ἢ ἀπαγωγὴ προσεγέγραπτ᾽ ἂν ἐν τοῖς νόμοις ‘τὸν δ᾽ ἐνδειχθέντα ἢ ἀπαχθέντα δησάντων οἱ ἕνδεκα ἐν τῷ ξύλῳ,’ εἴπερ μὴ ἐξῆν ἄλλους ἢ τοὺς ἐπὶ προδοσίᾳ τῆς πόλεως ἢ ἐπὶ καταλύσει τοῦ δήμου συνιόντας ἢ τοὺς τὰ τέλη ὠνουμένους καὶ μὴ καταβάλλοντας δῆσαι."σει τοῦ δήμου συνιόντας ἢ τοὺς τὰ τέλη ὠνουμένους καὶ μὴ καταβάλλοντας δῆσαι.</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_initiated_by_investigation_by_the_Council_of_the_Areopagus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_maltreatment_of_parents_orphans_and_heiresses_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_non-assessable_penalty_has_punishment_for_convicted_of_death_has_no_penalty_for_failed_prosecution"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_withholding_property_from_the_state_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_an_inventory_of_owed_property_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_confiscation_of_owed_property_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
