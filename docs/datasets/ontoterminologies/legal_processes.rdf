    <otv:Term rdf:about="#ἀστρατείας γραφή_grc">
        <rdfs:label xml:lang="grc">ἀστρατείας γραφή</rdfs:label>
        <otv:termName>ἀστρατείας γραφή</otv:termName>
        <otv:language>grc</otv:language>
        <otv:denotedConcept rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_avoiding_military_service_supervised_by_Strategoi_tried_by_the_dikasterion_has_punishment_for_convicted_of_disenfranchisement_with_non-assessable_penalty"/>
        <otv:termStatus>preferred</otv:termStatus>
        <otv:partOfSpeech>none</otv:partOfSpeech>
        <otv:gender>none</otv:gender>
        <otv:termDefinition>Γραφή for avoiding military service, supervised by Strategoi, tried by the dikasterion, has punishment for convicted of disenfranchisement, with non-assessable penalty.</otv:termDefinition>
        <skos:definition xml:lang="grc">Γραφή for avoiding military service, supervised by Strategoi, tried by the dikasterion, has punishment for convicted of disenfranchisement, with non-assessable penalty.</skos:definition>
        <otv:context xml:lang="grc">Lys. 15.1: "ἐγὼ μέν, ὦ ἄνδρες δικασταί, καὶ ὑμᾶς αἰτοῦμαι τὰ δίκαια ψηφίσασθαι, καὶ τῶν στρατηγῶν δέομαι, ἐπεὶ καὶ ἐν τῇ ἄλλῃ ἀρχῇ πολλοῦ ἄξιοι τῇ πόλει γεγόνασι, καὶ τῶν τῆς ἀστρατείας γραφῶν κοινοὺς εἶναι τῷ τε διώκοντι καὶ τῷ φεύγοντι, καὶ μὴ βοηθοῦντας ᾧ ἂν βούλωνται πᾶσαν προθυμίαν ἔχειν παρὰ τὸ δίκαιον ὑμᾶς ψηφίσασθαι,"</otv:context>
    </otv:Term>

    <otv:Term rdf:about="#διαδικασία_grc">
        <rdfs:label xml:lang="grc">διαδικασία</rdfs:label>
        <otv:termName>διαδικασία</otv:termName>
        <otv:language>grc</otv:language>
        <otv:denotedConcept rdf:resource="#Legal_proceeding_with_multiple_claimants_for_inheritance_dispute_initiated_by_competing_claims_for_inheritance_supervised_by_Eponymous_Archon_tried_by_the_dikasterion"/>
        <otv:termStatus>preferred</otv:termStatus>
        <otv:partOfSpeech>none</otv:partOfSpeech>
        <otv:gender>none</otv:gender>
        <otv:termDefinition>A δίκη with multiple claimants for an inheritance dispute, initiated by competing claims for inheritance, supervised by the Eponymous Archon and tried by the dikasterion.</otv:termDefinition>
        <skos:definition xml:lang="grc">A δίκη with multiple claimants for an inheritance dispute, initiated by competing claims for inheritance, supervised by the Eponymous Archon and tried by the dikasterion.</skos:definition>
        <otv:context xml:lang="grc">Dem. 24.54: "ὅσων δίκη πρότερον ἐγένετο ἢ εὔθυνα ἢ διαδικασία περί του ἐν δικαστηρίῳ, ἢ ἰδίᾳ ἢ δημοσίᾳ, ἢ τὸ δημόσιον ἀπέδοτο, μὴ εἰσάγειν περὶ τούτων εἰς τὸ δικαστήριον μηδ᾽ ἐπιψηφίζειν τῶν ἀρχόντων μηδένα, μηδὲ κατηγορεῖν ἐώντων ἃ οὐκ ἐῶσιν οἱ νόμοι.”</otv:context>
        <otv:context xml:lang="grc">Dem. 43.61: "ἔστιν δ᾽ ὁ νῦν ἀγὼν καὶ ἡ διαδικασία οὐκ εἴ τις ἕτερος ἑτέρου πρότερος ἢ ὕστερος τετελεύτηκεν, ἀλλ᾽ εἰ μὴ προσήκει ἐξελαθῆναι ἐκ τοῦ οἴκου τοῦ Ἁγνίου τοὺς οἰκείους τοὺς Ἁγνίου, ἀνεψιοὺς ὄντας καὶ ἀνεψιῶν παῖδας Ἁγνίᾳ πρὸς πατρός, ὑπὸ τῶν ἐκ τοῦ Στρατίου οἴκου καὶ μηδὲν προσηκόντων ὥστε κληρονομεῖν τῶν Ἁγνίου, ἀλλὰ γένει ἀπωτέρω ὄντων. περὶ τούτου νῦν ἐσθ᾽ ὁ ἀγών."</otv:context>
    </otv:Term>

    <otv:Term rdf:about="#ἀργυρίου δίκη_grc">
        <rdfs:label xml:lang="grc">ἀργυρίου δίκη</rdfs:label>
