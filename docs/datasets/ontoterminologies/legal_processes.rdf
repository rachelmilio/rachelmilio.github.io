    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_recover_a_sum_of_money_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit for recovery</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for recovery</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit to recover a sum of money, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">ἀργυρίου δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀργυρίου δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι to recover a sum of money, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q20158244"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">homicide suit</rdfs:label>
        <skos:prefLabel xml:lang="en">homicide suit</skos:prefLabel>
        <skos:definition xml:lang="en">Lawsuit brought forward by relatives of victim, defendant summoned by proclamation at funeral of victim, initiated with a proclamation at funeral of victim, supervised by Basileus, with a prosecutor and defendant, has no penalty for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">φόνος δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">φόνος δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκη brought forward by relatives of victim, defendant summoned by proclamation at funeral of victim, initiated with a proclamation at funeral of victim, supervised by Basileus, with a prosecutor and defendant, has no penalty for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty_for_intentional_homicide_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_death_and_confiscation_of_property"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty_for_unintentional_homicide_tried_by_the_Ephetai_has_punishment_for_convicted_of_exile"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty_for_unintentional_homicide_tried_by_the_Ephetai_has_punishment_for_convicted_of_exile">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">unintentional homicide suit</rdfs:label>
        <skos:prefLabel xml:lang="en">unintentional homicide suit</skos:prefLabel>
        <skos:definition xml:lang="en">Homicide suit for unintentional homicide, tried by the Ephetai, has punishment for convicted of exile.</skos:definition>
        <rdfs:label xml:lang="grc">φόνος ἀκούσιος δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">φόνος ἀκούσιος δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Φόνος δίκη for unintentional homicide, tried by the Ephetai, has punishment for convicted of exile.</skos:definition>
        <skos:example xml:lang="grc">Antiph. 3 3.7: "ἀκουσίως δὲ οὐχ ἧσσον ἢ ἑκουσίως ἀποκτείναντες1 μου τὸν παῖδα, τὸ παράπαν δ᾽ ἀρνούμενοι2 μὴ ἀποκτεῖναι αὐτόν, οὐδ᾽ ὑπὸ τοῦ νόμου καταλαμβάνεσθαί φασιν,3 ὃς ἀπαγορεύει μήτε δικαίως μήτε ἀδίκως ἀποκτείνειν. ἀλλὰ τίς ὁ βαλών; εἰς τίν᾽ ὁ φόνος ἀνήκει;4 εἰς τοὺς θεωμένους ἢ εἰς τοὺς παιδαγωγοὺς, ὧν οὐδεὶς οὐδὲν κατηγορεῖ; οὐ γὰρ ἀφανὴς ἀλλὰ καὶ λίαν φανερὸς ἔμοιγε αὐτοῦ ὁ θάνατός ἐστιν. ἐγὼ δὲ τὸν νόμον ὀρθῶς ἀγορεύειν φημὶ τοὺς ἀποκτείναντας κολάζεσθαι: ὅ τε γὰρ ἄκων ἀποκτείνας ἀκουσίοις κακοῖς περιπεσεῖν δίκαιός ἐστιν, ὅ τε διαφθαρεὶς οὐδὲν ἧσσον ἀκουσίως ἢ ἑκουσίως βλαφθεὶς ἀδικοῖτ᾽ ἂν ἀτιμώρητος γενόμενος."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit initiated by submitting a charge in writing to magistrate, defendant summoned by plaintiff via prosklesis, has penalty of 1000 drachmas for failed prosecution.</skos:definition>
        <rdfs:label xml:lang="grc">γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι initiated by submitting a charge in writing to magistrate, defendant summoned by plaintiff via prosklesis, has penalty of 1000 drachmas for failed prosecution.</skos:definition>
        <skos:example xml:lang="grc">Antiph. 1.2: "ἡ γὰρ τύχη καὶ αὐτοὶ οὗτοι ἠνάγκασαν ἐμοὶ πρὸς τούτους αὐτοὺς τὸν ἀγῶνα καταστῆναι, οὓς εἰκὸς ἦν τῷ μὲν τεθνεῶτι τιμωροὺς γενέσθαι, τῷ δ᾽ ἐπεξιόντι βοηθούς. νῦν δὲ τούτων τἀναντία γεγένηται: αὐτοὶ γὰρ οὗτοι καθεστᾶσιν ἀντίδικοι καὶ φονῆς, ὡς καὶ ἐγὼ καὶ ἡ γραφὴ λέγει."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_conspiracy_and_bribery_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_ten_times_fine_and_hereditary_disenfranchisement_with_non-assessable_penalty"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_impiety_supervised_by_Basileus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_with_assessable_penalty_through_timesis"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_destruction_of_sacred_olive_trees_supervised_by_Basileus_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_death_with_non-assessable_penalty"/>
