        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_withholding_property_from_the_state_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_an_inventory_of_owed_property_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_confiscation_of_owed_property_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_illegally_addressing_the_Assembly_defendant_summoned_by_proclamation_in_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_disenfranchisement_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
