        <ontolex:denotes rdf:resource="#Legal_Stage_for_prosecutor_to_summon_defendant_to_magistrate_before_one_or_more_kleteres_in_non_homicide_suits_where_defendant_is_not_arrested"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#δίκη_προικός_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_δίκη_προικός_grc">
                <ontolex:writtenRep xml:lang="grc">δίκη προικός</ontolex:writtenRep>
            </ontolex:Form>
