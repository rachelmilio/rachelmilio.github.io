    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#τίμησις_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_τίμησις_grc">
                <ontolex:writtenRep xml:lang="grc">τίμησις</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_τίμησις_grc">
                <ontolex:isEvokedBy rdf:resource="#τίμησις_grc"/>
                <skos:definition xml:lang="grc">Stage of lawsuit for litigants to propose penalties for convicted defendant, before the dikasterion, in assessable lawsuits.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_Stage_for_litigants_to_propose_penalties_for_convicted_defendant_before_the_dikasterion_in_assessable_lawsuits"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#εἰσαγγελία_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_εἰσαγγελία_grc">
                <ontolex:writtenRep xml:lang="grc">εἰσαγγελία</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_εἰσαγγελία_grc">
                <ontolex:isEvokedBy rdf:resource="#εἰσαγγελία_grc"/>
                <skos:definition xml:lang="grc">Δίκαι δημόσιαι for subversion or treason or bribery of public speakers, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, with non-assessable penalty, has punishment for convicted of death, has no penalty for failed prosecution.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_non-assessable_penalty_has_punishment_for_convicted_of_death_has_no_penalty_for_failed_prosecution"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#παρανόμων γραφή_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_παρανόμων γραφή_grc">
                <ontolex:writtenRep xml:lang="grc">παρανόμων γραφή</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_παρανόμων γραφή_grc">
                <ontolex:isEvokedBy rdf:resource="#παρανόμων γραφή_grc"/>
                <skos:definition xml:lang="grc">Γραφή for proposing or enacting an illegal law, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_proposing_or_enacting_an_illegal_law_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#δώρων_γραφή_grc">
        <ontolex:lexicalForm>
