	<!--  SKOS Concept Scheme -->

    <skos:ConceptScheme rdf:about="http://www.ontologia.fr/OTB/legal_processes">
        <dc:title>Athenian-Legal-Processes</dc:title>
        <dc:description>This is version 2.0 of a database for the PhD "Semantic Annotation and Attic Oratory" that defines the primary legal proceedings in Classical Athenian courts c. 419 BC to 323 BC. I define a legal proceeding as a court dispute between two litigants, for which a forensic speech would be written. This work draws upon the corpus of Attic oratory as well as The Law of Ancient Athens by David D. Phillips and the Shape of Athenian Law by S.C. Todd. </dc:description>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-07-12</dc:issued>
        <dc:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-10-10</dc:modified>
        <dc:creator>Rachel Milio</dc:creator>
        <dc:publisher>University of Crete</dc:publisher>
    </skos:ConceptScheme>

	<!--  SKOS Concepts -->

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_theft_of_private_property_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_double_damages_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit for theft</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for theft</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit for theft of private property, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of double damages, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">κλοπῆς δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">κλοπῆς δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι for theft of private property, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of double damages, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 3.10: "πολλοὶ γὰρ πάνυ τῶν ὑπευθύνων, ἐπ᾽ αὐτοφώρῳ κλέπται τῶν δημοσίων χρημάτων ὄντες ἐξελεγχόμενοι, διεφύγγανον ἐκ τῶν δικαστηρίων, εἰκότως: ᾐσχύνοντο γὰρ οἶμαι οἱ δικασταί, εἰ φανήσεται ὁ αὐτὸς ἀνὴρ ἐν τῇ αὐτῇ πόλει, πρώην1 μέν ποτε ἀναγορευόμενος ἐν τοῖς ἀγῶσιν, ὅτι στεφανοῦται ἀρετῆς ἕνεκα καὶ δικαιοσύνης ὑπὸ τοῦ δήμου χρυσῷ στεφάνῳ, ὁ δὲ αὐτὸς ἀνὴρ μικρὸν ἐπισχὼν ἔξεισιν ἐκ τοῦ δικαστηρίου κλοπῆς ἕνεκα τὰς εὐθύνας ὠφληκώς: ὥστε ἠναγκάζοντο τὴν ψῆφον φέρειν οἱ δικασταί, οὐ περὶ τοῦ παρόντος ἀδικήματος,"</skos:example>
        <skos:example xml:lang="grc">Dem. 22.26: "δεῖν δ᾽ ᾤετο μηδέν᾽ ἀποστερεῖσθαι τοῦ δίκης τυχεῖν, ὡς ἕκαστος δύναται. πῶς οὖν ἔσται τοῦτο; ἐὰν πολλὰς ὁδοὺς δῷ διὰ τῶν νόμων ἐπὶ τοὺς ἠδικηκότας οἷον τῆς κλοπῆς. ἔρρωσαι καὶ σαυτῷ πιστεύεις: ἄπαγε: ἐν χιλίαις δ᾽ ὁ κίνδυνος. ἀσθενέστερος εἶ: τοῖς ἄρχουσιν ἐφηγοῦ: τοῦτο ποιήσουσιν ἐκεῖνοι. φοβεῖ καὶ τοῦτο: γράφου."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_non-assessable_penalty_has_punishment_for_convicted_of_death_has_no_penalty_for_failed_prosecution">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">impeachment for treason</rdfs:label>
        <skos:prefLabel xml:lang="en">impeachment for treason</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for subversion or treason or bribery of public speakers, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, with non-assessable penalty, has punishment for convicted of death, has no penalty for failed prosecution.</skos:definition>
        <rdfs:label xml:lang="grc">εἰσαγγελία</rdfs:label>
        <skos:prefLabel xml:lang="grc">εἰσαγγελία</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for subversion or treason or bribery of public speakers, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, with non-assessable penalty, has punishment for convicted of death, has no penalty for failed prosecution.</skos:definition>
        <skos:example xml:lang="grc">Andoc. 1.43: "ἡ μὲν εἰσαγγελία αὐτῷ, ὦ ἄνδρες, τοιαύτη: ἀπογράφει δὲ τὰ ὀνόματα τῶν ἀνδρῶν ὧν ἔφη γνῶναι, δύο καὶ τετταράκοντα, πρώτους μὲν Μαντίθεον καὶ Ἀψεφίωνα, βουλευτὰς ὄντας καὶ καθημένους ἔνδον, εἶτα δὲ καὶ τοὺς ἄλλους. ἀναστὰς δὲ Πείσανδρος ἔφη χρῆναι λύειν τὸ ἐπὶ Σκαμανδρίου ψήφισμα καὶ ἀναβιβάζειν ἐπὶ τὸν τροχὸν τοὺς ἀπογραφέντας, ὅπως μὴ πρότερον νὺξ ἔσται πρὶν πυθέσθαι τοὺς ἄνδρας ἅπαντας. ἀνέκραγεν ἡ βουλὴ ὡς εὖ λέγει."</skos:example>
        <skos:example xml:lang="grc">Dem. 21.121: "Λυσίμαχος Ἀλωπεκῆθεν, Δημέας Σουνιεύς, Χάρης Θορίκιος, Φιλήμων Σφήττιος, Μόσχος Παιανιεύς, καθ᾽ οὓς καιροὺς ἡ εἰσαγγελία ἐδόθη εἰς τὴν βουλὴν ὑπὲρ Ἀριστάρχου τοῦ Μόσχου, ὅτι εἴη Νικόδημον ἀπεκτονώς, οἴδαμεν Μειδίαν τὸν κρινόμενον ὑπὸ Δημοσθένους, ᾧ μαρτυροῦμεν, ἐλθόντα πρὸς τὴν βουλὴν καὶ λέγοντα μηδένα ἕτερον εἶναι τὸν Νικοδήμου φονέα, ἀλλ᾽ Ἀρίσταρχον, καὶ τοῦτον αὐτοῦ γεγονέναι αὐτόχειρα, καὶ συμβουλεύοντα τῇ βουλῇ βαδίζειν ἐπὶ τὴν οἰκίαν τὴν Ἀριστάρχου καὶ συλλαμβάνειν αὐτόν."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis_for_violations_at_religious_festivals">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">presentation against violations at religious festivals</rdfs:label>
        <skos:prefLabel xml:lang="en">presentation against violations at religious festivals</skos:prefLabel>
        <skos:definition xml:lang="en">Presentation for violations at religious festivals.</skos:definition>
        <rdfs:label xml:lang="grc">προβολή ἠδικηκὼς τῆς ἑορτῆς</rdfs:label>
        <skos:prefLabel xml:lang="grc">προβολή ἠδικηκὼς τῆς ἑορτῆς</skos:prefLabel>
        <skos:definition xml:lang="grc">Προβολή for violations at religious festivals.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_to_overturn_decision_of_a_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">appeal</rdfs:label>
        <skos:prefLabel xml:lang="en">appeal</skos:prefLabel>
        <skos:definition xml:lang="en">Lawsuit to overturn decision of a magistrate, supervised by the Thesmothetai, tried by the dikasterion.</skos:definition>
        <rdfs:label xml:lang="grc">ἔφεσις</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἔφεσις</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκη to overturn decision of a magistrate, supervised by the Thesmothetai, tried by the dikasterion.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q113646374"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Stage_for_litigants_to_introduce_their_claims_and_evidence_and_be_questioned_before_the_appropriate_magistrate_in_homicide_suits">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">pre-trial conference</rdfs:label>
        <skos:prefLabel xml:lang="en">pre-trial conference</skos:prefLabel>
        <skos:definition xml:lang="en">Stage of lawsuit for litigants to introduce their claims and evidence and be questioned, before the appropriate magistrate, in homicide suits.</skos:definition>
        <rdfs:label xml:lang="en">prodikasia</rdfs:label>
        <skos:altLabel xml:lang="en">prodikasia</skos:altLabel>
        <rdfs:label xml:lang="grc">προδικασία</rdfs:label>
        <skos:prefLabel xml:lang="grc">προδικασία</skos:prefLabel>
        <skos:definition xml:lang="grc">Stage of lawsuit for litigants to introduce their claims and evidence and be questioned, before the appropriate magistrate, in homicide suits.</skos:definition>
        <skos:broader rdf:resource="#Legal_Stage"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_crimes_of_hubris_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for hubris</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for hubris</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for crimes of hubris, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <rdfs:label xml:lang="grc">ὕβρεως γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ὕβρεως γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for crimes of hubris, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <skos:example xml:lang="grc">Dem. 37.33: "ἐνταυθὶ πόλλ᾽ ἄττα καὶ δεινά μοι ἅμ᾽ ἐγκαλεῖ: καὶ γὰρ αἴκειαν καὶ ὕβριν καὶ βιαίων καὶ πρὸς ἐπικλήρους ἀδικήματα. τούτων δ᾽ εἰσὶν ἑκάστου χωρὶς αἱ δίκαι καὶ οὔτε πρὸς ἀρχὴν τὴν αὐτὴν οὔθ᾽ ὑπὲρ τιμημάτων τῶν αὐτῶν, ἀλλ᾽ ἡ μὲν αἴκεια καὶ τὰ τῶν βιαίων πρὸς τοὺς τετταράκοντα, αἱ δὲ τῆς ὕβρεως πρὸς τοὺς θεσμοθέτας, ὅσα δ᾽ εἰς ἐπικλήρους, πρὸς τὸν ἄρχοντα. οἱ δὲ νόμοι καὶ τούτων διδόασι τὰς παραγραφὰς ἀντιλαγχάνειν, περὶ ὧν οὐκ εἰσὶν εἰσαγωγεῖς. λέγε δ᾽ αὐτοῖς τουτονὶ τὸν νόμον."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q19996435"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_impiety_supervised_by_Basileus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for impiety</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for impiety</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for impiety, supervised by Basileus, tried by the dikasterion, has punishment for convicted of a penal assessment, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">ἀσεβείας γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀσεβείας γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for impiety, supervised by Basileus, tried by the dikasterion, has punishment for convicted of a penal assessment, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 22.2: "αἰτιασάμενος γάρ με, ἃ καὶ λέγειν ἂν ὀκνήσειέ τις, εἰ μὴ τύχοι προσόμοιος ὢν τούτῳ, τὸν πατέρ᾽ ὡς ἀπέκτον᾽ ἐγὼ τὸν ἐμαυτοῦ, καὶ κατασκευάσας ἀσεβείας γραφὴν οὐκ ἐπ᾽ ἐμέ, ἀλλ᾽ ἐπὶ τὸν θεῖόν μου, γράψας ἀσεβεῖν ἐμοὶ συνιόντ᾽ εἰς ταὐτὸν ὡς πεποιηκότι ταῦτα, εἰς ἀγῶνα κατέστησεν: ὃν εἰ συνέβη τόθ᾽ ἁλῶναι, τίς ἂν ἀθλιώτερ᾽ ἐμοῦ πεπονθὼς ἦν ὑπὸ τούτου; τίς γὰρ ἂν ἢ φίλος ἢ ξένος εἰς ταὐτό ποτ᾽ ἐλθεῖν ἠθέλησεν ἐμοί; τίς δ᾽ ἂν εἴασε πόλις που παρ᾽ ἑαυτῇ γενέσθαι τὸν τὸ τοιοῦτ᾽ ἀσέβημα δοκοῦντ᾽ εἰργάσθαι; οὐκ ἔστιν οὐδὲ μία."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q19992130"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_causing_financial_loss_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit for damages</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for damages</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit for causing financial loss, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">βλάβης δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">βλάβης δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι for causing financial loss, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 49.20: "νυνὶ δὲ τῷ Ἀντιφάνει εἴληχα βλάβης ἰδίαν δίκην, ὅτι μοι οὔτ᾽ ἐμαρτύρησεν οὔτ᾽ ἐξωμόσατο κατὰ τὸν νόμον. καὶ ἀξιῶ αὐτὸν ἀναβάντα εἰπεῖν ἐναντίον ὑμῶν διομοσάμενον, πρῶτον μὲν εἰ ἐδάνεισε Τιμοθέῳ ἐν Καλαυρείᾳ χιλίας δραχμάς, δεύτερον δ᾽ εἰ παρὰ τοῦ πατρὸς Φίλιππος ἀπέλαβεν ἐνθάδε τοῦτο τὸ ἀργύριον."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q19993869"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_initiated_by_investigation_by_the_Council_of_the_Areopagus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">report</rdfs:label>
        <skos:prefLabel xml:lang="en">report</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for subversion or treason or bribery of public speakers, initiated by investigation by the Council of the Areopagus, tried by the dikasterion, has punishment for convicted of a penal assessment, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">ἀπόφασις</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀπόφασις</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for subversion or treason or bribery of public speakers, initiated by investigation by the Council of the Areopagus, tried by the dikasterion, has punishment for convicted of a penal assessment, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">presentation</rdfs:label>
        <skos:prefLabel xml:lang="en">presentation</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit defendant summoned by proclamation in the Assembly, initiated by vote before the Assembly, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a penal assessment, has penalty of 1000 drachmas for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">προβολή</rdfs:label>
        <skos:prefLabel xml:lang="grc">προβολή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι defendant summoned by proclamation in the Assembly, initiated by vote before the Assembly, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a penal assessment, has penalty of 1000 drachmas for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 21.193: "οἶμαι τοίνυν αὐτὸν οὐδὲ τοῦ δήμου κατηγορεῖν ὀκνήσειν οὐδὲ τῆς ἐκκλησίας, ἀλλ᾽ ἅπερ τότ᾽ ἐτόλμα λέγειν ὅτ᾽ ἦν ἡ προβολή, ταῦτα καὶ νῦν ἐρεῖν, ὡς ὅσοι δέον ἐξιέναι κατέμενον καὶ ὅσοι τὰ φρούρι᾽ ἦσαν ἔρημα λελοιπότες, ἐξεκλησίασαν, καὶ χορευταὶ καὶ ξένοι καὶ τοιοῦτοί τινες ἦσαν οἳ κατεχειροτόνησαν αὐτοῦ."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis_for_deceiving_the_people"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis_for_violations_at_religious_festivals"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_initiated_by_plaintiff_arresting_defendant_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">summary arrest</rdfs:label>
        <skos:prefLabel xml:lang="en">summary arrest</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for theft or murder or illegal exercise of citizen rights, defendant summoned by arrest, initiated by plaintiff arresting defendant, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἀπαγωγή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀπαγωγή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for theft, murder, or illegal exercise of citizen rights, in which the defendant is summoned by arrest, initiated by plaintiff arresting defendant, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 24.146: "ὡς δὲ σαφῶς γνώσεσθ᾽ ὅτι ἀληθῆ λέγω, ἐγὼ ὑμῖν ἐρῶ. οὔτε γὰρ ἄν, ὦ ἄνδρες δικασταί, τιμᾶν ἐξῆν ὑμῖν ὅ τι χρὴ παθεῖν ἢ ἀποτεῖσαι （ἐν γὰρ τῷ παθεῖν καὶ ὁ δεσμὸς ἔνι: οὐκ ἂν οὖν ἐξῆν δεσμοῦ τιμῆσαι）, οὔθ᾽ ὅσων ἔνδειξίς ἐστιν ἢ ἀπαγωγὴ προσεγέγραπτ᾽ ἂν ἐν τοῖς νόμοις ‘τὸν δ᾽ ἐνδειχθέντα ἢ ἀπαχθέντα δησάντων οἱ ἕνδεκα ἐν τῷ ξύλῳ,’ εἴπερ μὴ ἐξῆν ἄλλους ἢ τοὺς ἐπὶ προδοσίᾳ τῆς πόλεως ἢ ἐπὶ καταλύσει τοῦ δήμου συνιόντας ἢ τοὺς τὰ τέλη ὠνουμένους καὶ μὴ καταβάλλοντας δῆσαι."σει τοῦ δήμου συνιόντας ἢ τοὺς τὰ τέλη ὠνουμένους καὶ μὴ καταβάλλοντας δῆσαι.</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_evaluate_a_potential_magistrate_initiated_before_term_of_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">scrutiny</rdfs:label>
        <skos:prefLabel xml:lang="en">scrutiny</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit to evaluate a potential magistrate, initiated before term of magistrate, supervised by the Thesmothetai, tried by the dikasterion.</skos:definition>
        <rdfs:label xml:lang="grc">δοκιμασία</rdfs:label>
        <skos:prefLabel xml:lang="grc">δοκιμασία</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι to evaluate a potential magistrate, initiated before term of magistrate, supervised by the Thesmothetai, tried by the dikasterion.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 1.28: "τίνας δ᾽ οὐκ ᾤετο δεῖν λέγειν; τοὺς αἰσχρῶς βεβιωκότας: τούτους οὐκ ἐᾷ δημηγορεῖν. καὶ ποῦ τοῦτο δηλοῖ; ‘δοκιμασία,’ φησί, ‘ῥητόρων: ἐάν τις λέγῃ ἐν τῷ δήμῳ τὸν πατέρα τύπτων ἢ τὴν μητέρα, ἢ μὴ τρέφων, ἢ μὴ παρέχων οἴκησιν:’ τοῦτον οὐκ ἐᾷ λέγειν. νὴ Δία καλῶς γε, ὡς ἔγωγέ φημι. διὰ τί; ὅτι εἴ τις, οὓς ἐξ ἴσου δεῖ τιμᾶν τοῖς θεοῖς, εἰς τούτους ἐστὶ φαῦλος, τί ποτε, φησίν, ὑπ᾽ αὐτοῦ πείσονται οἱ ἀλλότριοι καὶ ἡ πόλις ὅλη; καὶ τίσι δεύτερον ἀπεῖπε μὴ λέγειν; ‘ἢ τὰς στρατείας,’"</skos:example>
        <skos:example xml:lang="grc">Lys. 26.16: "καίτοιγε αὐτὸν ἀκούω λέξειν ὡς οὐ περὶ αὐτοῦ μόνον ἡ δοκιμασία ἐστίν, ἀλλὰ περὶ πάντων τῶν ἐν ἄστει μεινάντων, καὶ τοὺς ὅρκους καὶ τὰς συνθήκας ὑμᾶς ὑπομνήσειν, ὡς ἐκ τούτων προσληψόμενον αὐτὸν δοκιμαστὰς τοὺς ἐν ἄστει μείναντας. ἐγὼ δ᾽ ὑπὲρ τοῦ πλήθους βραχέα πρὸς αὐτὸν εἰπεῖν βούλομαι, ὅτι ὁ δῆμος οὐ τὴν αὐτὴν γνώμην ἔχει περὶ πάντων τῶν ἐν ἄστει μεινάντων, ἀλλὰ περὶ μὲν τῶν τοιαῦτα ἐξαμαρτανόντων οἵαν ἐγώ φημι δεῖν,"</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q95983976"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <skos:topConceptOf rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">lawsuit</rdfs:label>
        <skos:prefLabel xml:lang="en">lawsuit</skos:prefLabel>
        <skos:definition xml:lang="en"> is an entire legal process.</skos:definition>
        <rdfs:label xml:lang="grc">δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">A legal proceeding in the classical Athenian court system.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 1.44: "ᾗ δὴ καὶ πάνυ χαίρω, ὅτι μοι γέγονεν ἡ δίκη πρὸς ἄνθρωπον οὐκ ἠγνοημένον ὑφ᾽ ὑμῶν, οὐδ᾽ ἀπ᾽ ἄλλου γιγνωσκόμενον οὐδενός, ἢ ἀπ᾽ αὐτοῦ τοῦ ἐπιτηδεύματος περὶ οὗ καὶ τὴν ψῆφον μέλλετε φέρειν."</skos:example>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
        <skos:narrower rdf:resource="#Legal_proceeding_with_non-assessable_penalty"/>
        <skos:narrower rdf:resource="#Legal_proceeding_with_assessable_penalty_through_timesis"/>
        <skos:narrower rdf:resource="#Legal_proceeding_with_multiple_claimants_for_inheritance_dispute_initiated_by_competing_claims_for_inheritance_supervised_by_Eponymous_Archon_tried_by_the_dikasterion"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty"/>
        <skos:narrower rdf:resource="#Legal_proceeding_to_overturn_decision_of_a_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_examine_disabled_pension_recipient_tried_by_the_Council_has_punishment_for_convicted_of_losing_pension">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">scrutiny of pension recipients</rdfs:label>
        <skos:prefLabel xml:lang="en">scrutiny of pension recipients</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit to examine disabled pension recipient, tried by the Council, has punishment for convicted of losing pension.</skos:definition>
        <rdfs:label xml:lang="grc">δοκιμασία ἀδύνατοι</rdfs:label>
        <skos:prefLabel xml:lang="grc">δοκιμασία ἀδύνατοι</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι to examine disabled pension recipient, tried by the Council, has punishment for convicted of losing pension.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">assessable lawsuit</rdfs:label>
        <skos:prefLabel xml:lang="en">assessable lawsuit</skos:prefLabel>
        <skos:definition xml:lang="en">Lawsuit with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">δίκη τιμητή</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκη τιμητή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκη with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 27.67: "καὶ νῦν κομίσασθαι τἀμαυτοῦ ζητῶν εἰς κίνδυνον καθέστηκα τὸν μέγιστον. ἂν γὰρ ἀποφύγῃ μ᾽ οὗτος, ὃ μὴ γένοιτο, τὴν ἐπωβελίαν ὀφλήσω μνᾶς ἑκατόν. καὶ τούτῳ μέν, ἐὰν καταψηφίσησθε, τιμητόν, κοὐκ ἐκ τῶν ἑαυτοῦ χρημάτων, ἀλλ᾽ ἐκ τῶν ἐμῶν ποιήσεται τὴν ἔκτεισιν: ἐμοὶ δ᾽ ἀτίμητον τοῦτ᾽ ἔστιν, ὥστ᾽ οὐ μόνον ἔσομαι τῶν πατρῴων ἀπεστερημένος, ἀλλὰ καὶ πρὸς ἠτιμωμένος, ἂν μὴ νῦν ἡμᾶς ὑμεῖς ἐλεήσητε."</skos:example>
        <rdfs:label xml:lang="grc">ἀγών τιμητός</rdfs:label>
        <skos:altLabel xml:lang="grc">ἀγών τιμητός</skos:altLabel>
        <skos:definition xml:lang="grc">A δίκη with an assessable penalty through τίμησις.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_maltreatment_of_parents_orphans_and_heiresses_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">impeachment for maltreatment</rdfs:label>
        <skos:prefLabel xml:lang="en">impeachment for maltreatment</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for maltreatment of parents orphans and heiresses, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">εἰσαγγελία κάκωσις</rdfs:label>
        <skos:prefLabel xml:lang="grc">εἰσαγγελία κάκωσις</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for maltreatment of parents orphans and heiresses, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_against_guardian_witholding_property_from_ward_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit over a guardianship</rdfs:label>
        <skos:prefLabel xml:lang="en">suit over a guardianship</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit against guardian witholding property from ward, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">δίκη ἐπιτροπῆς</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκη ἐπιτροπῆς</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι against guardian witholding property from ward, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Isaeus 7.7: " ἀνδρί τε γενομένῳ συνηγωνίσατο καὶ εἰσέπραξε τὸ ἡμικλήριον ὧν Μνήσων κατέλιπεν ὅσα τε ἐκ τῆς ἐπιτροπῆς ἀπεστέρησε, δίκας δύο ἑλών, καὶ τὴν οὐσίαν ἐποίησε κομίσασθαι τὴν αὑτοῦ πᾶσαν."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_physically_obstructing_prosecutor_from_inheritance_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_restore_property_to_prosecutor_and_pay_cash_value_to_state_has_penalty_of_epobelia_for_failed_prosecution_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit for ejectment</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for ejectment</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit for physically obstructing prosecutor from inheritance, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of restore property to prosecutor and pay cash value to state, has penalty of epobelia for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἐξούλης δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἐξούλης δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι for physically obstructing prosecutor from inheritance, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of restore property to prosecutor and pay cash value to state, has penalty of epobelia for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 39.15: "ὅτι νὴ Δί᾽ εἴσονται πάντες πότερός ποτ᾽ ὦφλεν. καλῶς. ἂν δέ, ὃ τυχὸν γένοιτ᾽ ἄν, χρόνος διέλθῃ καὶ μὴ ἐκτεισθῇ τὸ ὄφλημα, τί μᾶλλον οἱ τούτου παῖδες ἔσονται τῶν ἐμῶν ἐγγεγραμμένοι, ὅταν τοὔνομα καὶ ὁ πατὴρ καὶ ἡ φυλὴ καὶ πάντ᾽ ᾖ ταὐτά; τί δ᾽, εἴ τις δίκην ἐξούλης αὐτῷ λαχὼν μηδὲν ἐμοὶ φαίη πρὸς αὑτὸν εἶναι, κυρίαν δὲ ποιησάμενος ἐγγράψαι, τί μᾶλλον ἂν εἴη τοῦτον ἢ ἔμ᾽ ἐγγεγραφώς; τί δ᾽, εἴ τινας εἰσφορὰς μὴ θείη;"</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q50964502"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_starting_a_physical_fight_without_justification_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">battery suit</rdfs:label>
        <skos:prefLabel xml:lang="en">battery suit</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit for starting a physical fight without justification, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">αἰκίας δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">αἰκίας δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι for starting a physical fight without justification, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 37.33: "
ἐνταυθὶ πόλλ᾽ ἄττα καὶ δεινά μοι ἅμ᾽ ἐγκαλεῖ: καὶ γὰρ αἴκειαν καὶ ὕβριν καὶ βιαίων καὶ πρὸς ἐπικλήρους ἀδικήματα. τούτων δ᾽ εἰσὶν ἑκάστου χωρὶς αἱ δίκαι καὶ οὔτε πρὸς ἀρχὴν τὴν αὐτὴν οὔθ᾽ ὑπὲρ τιμημάτων τῶν αὐτῶν, ἀλλ᾽ ἡ μὲν αἴκεια καὶ τὰ τῶν βιαίων πρὸς τοὺς τετταράκοντα, αἱ δὲ τῆς ὕβρεως πρὸς τοὺς θεσμοθέτας, ὅσα δ᾽ εἰς ἐπικλήρους, πρὸς τὸν ἄρχοντα. οἱ δὲ νόμοι καὶ τούτων διδόασι τὰς παραγραφὰς ἀντιλαγχάνειν, περὶ ὧν οὐκ εἰσὶν εἰσαγωγεῖς. λέγε δ᾽ αὐτοῖς τουτονὶ τὸν νόμον."</skos:example>
        <skos:example xml:lang="grc">Dem. 54.18: "φασὶ τοίνυν ταύτας διὰ τοῦτο γίγνεσθαι, ἵνα μὴ λοιδορούμενοι τύπτειν ἀλλήλους προάγωνται. πάλιν αἰκείας εἰσί: καὶ ταύτας ἀκούω διὰ τοῦτ᾽ εἶναι τὰς δίκας, ἵνα μηδείς, ὅταν ἥττων ᾖ, λίθῳ μηδὲ τῶν τοιούτων ἀμύνηται μηδενί, ἀλλὰ τὴν ἐκ τοῦ νόμου δίκην ἀναμένῃ."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q19982824"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_withholding_property_from_the_state_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_an_inventory_of_owed_property_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_confiscation_of_owed_property_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for confiscation</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for confiscation</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for withholding property from the state, defendant summoned by plaintiff via prosklesis, initiated by submitting an inventory of owed property, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of confiscation of owed property, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἀπογραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀπογραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for withholding property from the state, defendant summoned by plaintiff via prosklesis, initiated by submitting an inventory of owed property, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of confiscation of owed property, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 53.3: "εἰ μὲν οὖν μοι ἦν ἱκανὸν τὸ ὕδωρ διηγήσασθαι πρὸς ὑμᾶς τὰ ἐξ ἀρχῆς, ὅσ᾽ ἀγαθὰ πεπονθότες ὑπ᾽ ἐμοῦ οἷά με εἰργασμένοι εἰσίν, εὖ οἶδ᾽ ὅτι ὑμεῖς τ᾽ ἄν μοι ἔτι μᾶλλον συγγνώμην εἴχετε τοῦ ὀργίζεσθαι αὐτοῖς, τούτους τ᾽ ἀνοσιωτάτους ἀνθρώπων ἡγήσασθε εἶναι: νῦν δ᾽ οὐδὲ διπλάσιόν μοι τούτου ὕδωρ ἱκανὸν ἂν γένοιτο. τὰ μὲν οὖν μέγιστα καὶ περιφανῆ τῶν ἀδικημάτων, καὶ ὁπόθεν ἡ ἀπογραφὴ αὕτη γέγονεν, ἐρῶ πρὸς ὑμᾶς, τὰ δὲ πολλὰ ἐάσω."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Stage">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <skos:topConceptOf rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">stage of lawsuit</rdfs:label>
        <skos:prefLabel xml:lang="en">stage of lawsuit</skos:prefLabel>
        <skos:definition xml:lang="en"> is a stage of a legal process.</skos:definition>
        <rdfs:label xml:lang="grc">stage of lawsuit</rdfs:label>
        <skos:prefLabel xml:lang="grc">stage of lawsuit</skos:prefLabel>
        <skos:narrower rdf:resource="#Legal_Stage_for_litigants_to_introduce_their_claims_and_evidence_and_be_questioned_before_the_appropriate_magistrate_in_all_suits_except_homicide_suits"/>
        <skos:narrower rdf:resource="#Legal_Stage_for_prosecutor_to_summon_defendant_to_magistrate_before_one_or_more_kleteres_in_non_homicide_suits_where_defendant_is_not_arrested"/>
        <skos:narrower rdf:resource="#Legal_Stage_for_litigants_to_propose_penalties_for_convicted_defendant_before_the_dikasterion_in_assessable_lawsuits"/>
        <skos:narrower rdf:resource="#Legal_Stage_for_litigants_to_introduce_their_claims_and_evidence_and_be_questioned_before_the_appropriate_magistrate_in_homicide_suits"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_avoiding_military_service_supervised_by_Strategoi_tried_by_the_dikasterion_has_punishment_for_convicted_of_disenfranchisement_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for avoiding military service</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for avoiding military service</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for avoiding military service, supervised by Strategoi, tried by the dikasterion, has punishment for convicted of disenfranchisement, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἀστρατείας γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀστρατείας γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for avoiding military service, supervised by Strategoi, tried by the dikasterion, has punishment for convicted of disenfranchisement, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Lys. 15.1: "ἐγὼ μέν, ὦ ἄνδρες δικασταί, καὶ ὑμᾶς αἰτοῦμαι τὰ δίκαια ψηφίσασθαι, καὶ τῶν στρατηγῶν δέομαι, ἐπεὶ καὶ ἐν τῇ ἄλλῃ ἀρχῇ πολλοῦ ἄξιοι τῇ πόλει γεγόνασι, καὶ τῶν τῆς ἀστρατείας γραφῶν κοινοὺς εἶναι τῷ τε διώκοντι καὶ τῷ φεύγοντι, καὶ μὴ βοηθοῦντας ᾧ ἂν βούλωνται πᾶσαν προθυμίαν ἔχειν παρὰ τὸ δίκαιον ὑμᾶς ψηφίσασθαι,"</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q34214774"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_destruction_of_sacred_olive_trees_supervised_by_Basileus_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_death_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for removal of sacred olive tree</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for removal of sacred olive tree</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for destruction of sacred olive trees, supervised by Basileus, tried by the Council of the Areopagus, has punishment for convicted of death, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἀσεβείας τοῦ σηκοῦ γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀσεβείας τοῦ σηκοῦ γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for destruction of sacred olive trees, supervised by Basileus, tried by the Council of the Areopagus, has punishment for convicted of death, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Lys. 7.2: "οὕτω δ᾽ ἄπορος ὁ ἀγών μοι καθέστηκεν, ὥστε ἀπεγράφην τὸ μὲν πρῶτον ἐλάαν ἐκ τῆς γῆς ἀφανίζειν, καὶ πρὸς τοὺς ἐωνημένους τοὺς καρποὺς τῶν μορίων πυνθανόμενοι προσῇσαν: ἐπειδὴ δ᾽ ἐκ τούτου τοῦ τρόπου ἀδικοῦντά με οὐδὲν εὑρεῖν ἐδυνήθησαν, νυνί με σηκόν φασιν1 ἀφανίζειν, ἡγούμενοι ἐμοὶ μὲν ταύτην τὴν αἰτίαν ἀπορωτάτην εἶναι ἀπελέγξαι,2 αὐτοῖς δὲ ἐξεῖναι μᾶλλον ὅ τι ἂν βούλωνται λέγειν."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Stage_for_litigants_to_introduce_their_claims_and_evidence_and_be_questioned_before_the_appropriate_magistrate_in_all_suits_except_homicide_suits">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">preliminary hearing</rdfs:label>
        <skos:prefLabel xml:lang="en">preliminary hearing</skos:prefLabel>
        <skos:definition xml:lang="en">Stage of lawsuit for litigants to introduce their claims and evidence and be questioned, before the appropriate magistrate, in all suits except homicide suits.</skos:definition>
        <rdfs:label xml:lang="en">anakrisis</rdfs:label>
        <skos:altLabel xml:lang="en">anakrisis</skos:altLabel>
        <rdfs:label xml:lang="grc">ἀνάκρασις</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀνάκρασις</skos:prefLabel>
        <skos:definition xml:lang="grc">Stage of lawsuit for litigants to introduce their claims and evidence and be questioned, before the appropriate magistrate, in all suits except homicide suits.</skos:definition>
        <skos:broader rdf:resource="#Legal_Stage"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_intentional_wounding_with_a_weapon_supervised_by_Basileus_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_exile_and_confiscation_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">intentional wounding suit</rdfs:label>
        <skos:prefLabel xml:lang="en">intentional wounding suit</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for intentional wounding with a weapon, supervised by Basileus, tried by the Council of the Areopagus, has punishment for convicted of exile and confiscation, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">τραύματος ἐκ προνοίας γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">τραύματος ἐκ προνοίας γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for intentional wounding with a weapon, supervised by Basileus, tried by the Council of the Areopagus, has punishment for convicted of exile and confiscation, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem 23.22: "δικάζειν δὲ τὴν βουλὴν τὴν ἐν Ἀρείῳ πάγῳ φόνου καὶ τραύματος ἐκ προνοίας καὶ πυρκαϊᾶς καὶ φαρμάκων, ἐάν τις ἀποκτείνῃ δούς."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">non-assessable lawsuit</rdfs:label>
        <skos:prefLabel xml:lang="en">non-assessable lawsuit</skos:prefLabel>
        <skos:definition xml:lang="en">Lawsuit with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">δίκη ἀτίμητη</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκη ἀτίμητη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκη with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 27.67: "καὶ νῦν κομίσασθαι τἀμαυτοῦ ζητῶν εἰς κίνδυνον καθέστηκα τὸν μέγιστον. ἂν γὰρ ἀποφύγῃ μ᾽ οὗτος, ὃ μὴ γένοιτο, τὴν ἐπωβελίαν ὀφλήσω μνᾶς ἑκατόν. καὶ τούτῳ μέν, ἐὰν καταψηφίσησθε, τιμητόν, κοὐκ ἐκ τῶν ἑαυτοῦ χρημάτων, ἀλλ᾽ ἐκ τῶν ἐμῶν ποιήσεται τὴν ἔκτεισιν: ἐμοὶ δ᾽ ἀτίμητον τοῦτ᾽ ἔστιν, ὥστ᾽ οὐ μόνον ἔσομαι τῶν πατρῴων ἀπεστερημένος, ἀλλὰ καὶ πρὸς ἠτιμωμένος, ἂν μὴ νῦν ἡμᾶς ὑμεῖς ἐλεήσητε."</skos:example>
        <rdfs:label xml:lang="grc">ἀγών ἀτίμητος</rdfs:label>
        <skos:altLabel xml:lang="grc">ἀγών ἀτίμητος</skos:altLabel>
        <skos:definition xml:lang="grc">A δίκη with a non-assessable penalty.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_illicit_consensual_sex_with_a_woman_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for seduction</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for seduction</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for illicit consensual sex with a woman, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <rdfs:label xml:lang="grc">μοιχείας γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">μοιχείας γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for illicit consensual sex with a woman, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <skos:example xml:lang="grc">Lys. 1.36: "οἷς ὑμᾶς ἀξιῶ τὴν αὐτὴν γνώμην ἔχειν: εἰ δὲ μή, τοιαύτην ἄδειαν τοῖς μοιχοῖς ποιήσετε, ὥστε1 καὶ τοὺς κλέπτας ἐπαρεῖτε φάσκειν μοιχοὺς εἶναι, εὖ εἰδότας ὅτι, ἐὰν ταύτην τὴν αἰτίαν περὶ ἑαυτῶν λέγωσι καὶ ἐπὶ τούτῳ φάσκωσιν εἰς τὰς ἀλλοτρίας οἰκίας εἰσιέναι, οὐδεὶς αὐτῶν ἅψεται. πάντες γὰρ εἴσονται ὅτι τοὺς μὲν νόμους τῆς μοιχείας χαίρειν ἐᾶν δεῖ, τὴν δὲ ψῆφον τὴν ὑμετέραν δεδιέναι: αὕτη γάρ ἐστι πάντων τῶν ἐν τῇ πόλει κυριωτάτη."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_inititated_by_plaintiff_denouncing_defendant_to_a_magistrate_for_arrest_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">denunciation</rdfs:label>
        <skos:prefLabel xml:lang="en">denunciation</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for theft or murder or illegal exercise of citizen rights, defendant summoned by arrest, inititated by plaintiff denouncing defendant to a magistrate for arrest, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἔνδειξις</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἔνδειξις</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for theft or murder or illegal exercise of citizen rights, defendant summoned by arrest, inititated by plaintiff denouncing defendant to a magistrate for arrest, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Andoc. 1.10: "ὥσπερ δὲ καὶ προεῖπον ὑμῖν, ὦ ἄνδρες, ἐξ ἀρχῆς περὶ πάντων ποιήσομαι τὴν ἀπολογίαν, πρῶτον μὲν περὶ αὐτῆς τῆς αἰτίας ὅθεν περ ἡ ἔνδειξις ἐγένετο, διόπερ εἰς τὸν ἀγῶνα τόνδε κατέστην, περὶ τῶν μυστηρίων"</skos:example>
        <skos:example xml:lang="grc">Dem. 24.22: "ἐὰν δ᾽ οἱ πρυτάνεις μὴ ποιήσωσι κατὰ τὰ γεγραμμένα τὴν ἐκκλησίαν ἢ οἱ πρόεδροι μὴ χρηματίσωσι, ὀφείλειν τῶν μὲν πρυτάνεων ἕκαστον χιλίας δραχμὰς ἱερὰς τῇ Ἀθηνᾷ, τῶν δὲ προέδρων ἕκαστος ὀφειλέτω τετταράκοντα δραχμὰς ἱερὰς τῇ Ἀθηνᾷ. καὶ ἔνδειξις αὐτῶν ἔστω πρὸς τοὺς θεσμοθέτας, καθάπερ ἐάν τις ἄρχῃ ὀφείλων τῷ δημοσίῳ: οἱ δὲ θεσμοθέται τοὺς ἐνδειχθέντας εἰσαγόντων εἰς τὸ δικαστήριον κατὰ τὸν νόμον, ἢ μὴ ἀνιόντων εἰς Ἄρειον πάγον, ὡς καταλύοντες τὴν ἐπανόρθωσιν τῶν νόμων."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_proposing_or_enacting_an_illegal_law_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for illegal proposals</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for illegal proposals</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for proposing or enacting an illegal law, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <rdfs:label xml:lang="grc">παρανόμων γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">παρανόμων γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for proposing or enacting an illegal law, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <skos:example xml:lang="grc">Dem. 18.13: " ἀλλ᾽ ἐφ᾽ οἷς ἀδικοῦντά μ᾽ ἑώρα τὴν πόλιν, οὖσί γε τηλικούτοις ἡλίκα νῦν ἐτραγῴδει καὶ διεξῄει, ταῖς ἐκ τῶν νόμων τιμωρίαις παρ᾽ αὐτὰ τἀδικήματα χρῆσθαι, εἰ μὲν εἰσαγγελίας ἄξια πράττονθ᾽ ἑώρα, εἰσαγγέλλοντα καὶ τοῦτον τὸν τρόπον εἰς κρίσιν καθιστάντα παρ᾽ ὑμῖν, εἰ δὲ γράφοντα παράνομα, παρανόμων γραφόμενον"</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_recover_a_deposit_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit for deposit recovery</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for deposit recovery</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit to recover a deposit, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">παρακαταθήκης δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">παρακαταθήκης δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι to recover a deposit, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_block_an_illegal_prosecution_initiated_by_defendant_at_anakrisis_supervised_by_Archon_from_initial_case_tried_by_the_dikasterion_has_punishment_for_convicted_of_one-sixth_the_sum_in_question_and_ends_litigation__has_penalty_of_epobelia_for_failed_prosecution_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">counter-indictment</rdfs:label>
        <skos:prefLabel xml:lang="en">counter-indictment</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit to block an illegal prosecution, initiated by defendant at anakrisis, supervised by Archon from initial case, tried by the dikasterion, has punishment for convicted of one-sixth the sum in question and ends litigation , has penalty of epobelia for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">παραγραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">παραγραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι to block an illegal prosecution, initiated by defendant at anakrisis, supervised by Archon from initial case, tried by the dikasterion, has punishment for convicted of one-sixth the sum in question and ends litigation , has penalty of epobelia for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 45.42: "οὐκοῦν ἐναντία μὲν ἡ παραγραφὴ πᾶσι τοῖς μεμαρτυρημένοις, ἐναντία δ᾽ ἣν ἀνέγνων ὑμῖν ἄρτι μίσθωσιν, τῇδε τῇ διαθήκῃ: οὐδὲν δὲ τῶν πεπραγμένων οὔτ᾽ εὔλογον οὔθ᾽ ἁπλοῦν οὔθ᾽ ὁμολογούμενον αὐτὸ ἑαυτῷ φαίνεται. ἐκ δὲ τούτου τοῦ τρόπου πάντα πεπλασμένα καὶ κατεσκευασμέν᾽ ἐλέγχεται." </skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_illegal_defamatory_speech_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_fixed_fine_has_penalty_of_epobelia_for_failed_prosecution_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">defamation suit</rdfs:label>
        <skos:prefLabel xml:lang="en">defamation suit</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit for illegal defamatory speech, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of fixed fine, has penalty of epobelia for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">κακηγορίας δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">κακηγορίας δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι for illegal defamatory speech, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of fixed fine, has penalty of epobelia for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 21.32: "ἴστε δήπου τοῦθ᾽ ὅτι τῶν θεσμοθετῶν τούτων οὐδενὶ θεσμοθέτης ἔστ᾽ ὄνομα, ἀλλ᾽ ὁτιδήποθ᾽ ἑκάστῳ. ἂν μὲν τοίνυν ἰδιώτην ὄντα τιν᾽ αὐτῶν ὑβρίσῃ τις ἢ κακῶς εἴπῃ, γραφὴν ὕβρεως καὶ δίκην κακηγορίας ἰδίαν φεύξεται, ἐὰν δὲ θεσμοθέτην, ἄτιμος ἔσται καθάπαξ. διὰ τί; ὅτι τοὺς νόμους ἤδη ὁ τοῦτο ποιῶν προσυβρίζει καὶ τὸν ὑμέτερον κοινὸν στέφανον καὶ τὸ τῆς πόλεως ὄνομα: ὁ γὰρ θεσμοθέτης οὐδενὸς ἀνθρώπων ἔστ᾽ ὄνομα, ἀλλὰ τῆς πόλεως."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_exercising_citizenship_rights_as_a_noncitizen_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_enslavement_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for false assertion of citizenship</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for false assertion of citizenship</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for exercising citizenship rights as a noncitizen, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of enslavement, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ξενίας γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">ξενίας γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for exercising citizenship rights as a noncitizen, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of enslavement, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Dem. 24.131: "μὴ τοίνυν αὐτοὶ διδάσκετε, ἀλλὰ τιμωρεῖσθε. καὶ μὴ ἐᾶτ᾽ ἀγανακτεῖν εἰ δεθήσονται ἔχοντες τὰ ὑμέτερα ἀλλ᾽ ἄγετ᾽ αὐτοὺς ὑπὸ τοὺς νόμους. οὐδὲ γὰρ οἱ τῆς ξενίας ἁλισκόμενοι ἀγανακτοῦσιν ἐν τῷ οἰκήματι τούτῳ ὄντες, ἕως ἂν τῶν ψευδομαρτυριῶν ἀγωνίσωνται, ἀλλὰ μένουσιν καὶ οὐκ οἴονται δεῖν ἐγγυητὰς καταστήσαντες περιιέναι."</skos:example>
        <skos:example xml:lang="grc">Isaeus 3.37: "ἆρ᾽ οὖν δοκεῖ τῳ ὑμῶν ὀλιγώρως οὕτως ἔχειν χρημάτων Νικόδημος, ὥστε παραλιπεῖν ἄν τι τῶν τοιούτων; ἐγὼ μὲν γὰρ οὐ νομίζω. εἶτα παρὰ τούτου ὁ ἡμέτερος θεῖος ἠξίωσεν ἂν ἐγγυήσασθαι τὴν ἀδελφήν, ὃς αὐτὸς ξενίας φεύγων ὑπὸ ἑνὸς τῶν φρατόρων ὧν φησιν αὑτοῦ εἶναι, παρὰ τέτταρας ψήφους μετέσχε τῆς πόλεως; καὶ ὡς ἀληθῆ λέγω, ἀναγίγνωσκε τὴν μαρτυρίαν."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_violent_acts_including_rape_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Forty_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">suit for acts of violence</rdfs:label>
        <skos:prefLabel xml:lang="en">suit for acts of violence</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit for violent acts including rape, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">βιαίων δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">βιαίων δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι for violent acts including rape, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Forty, tried by the dikasterion, has punishment for convicted of an assessable fine, has no penalty for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 37.33: "ἐνταυθὶ πόλλ᾽ ἄττα καὶ δεινά μοι ἅμ᾽ ἐγκαλεῖ: καὶ γὰρ αἴκειαν καὶ ὕβριν καὶ βιαίων καὶ πρὸς ἐπικλήρους ἀδικήματα. τούτων δ᾽ εἰσὶν ἑκάστου χωρὶς αἱ δίκαι καὶ οὔτε πρὸς ἀρχὴν τὴν αὐτὴν οὔθ᾽ ὑπὲρ τιμημάτων τῶν αὐτῶν, ἀλλ᾽ ἡ μὲν αἴκεια καὶ τὰ τῶν βιαίων πρὸς τοὺς τετταράκοντα, αἱ δὲ τῆς ὕβρεως πρὸς τοὺς θεσμοθέτας, ὅσα δ᾽ εἰς ἐπικλήρους, πρὸς τὸν ἄρχοντα. οἱ δὲ νόμοι καὶ τούτων διδόασι τὰς παραγραφὰς ἀντιλαγχάνειν, περὶ ὧν οὐκ εἰσὶν εἰσαγωγεῖς. λέγε δ᾽ αὐτοῖς τουτονὶ τὸν νόμον."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q19993732"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_conspiracy_and_bribery_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_ten_times_fine_and_hereditary_disenfranchisement_with_non-assessable_penalty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">indictment for accepting bribes</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for accepting bribes</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for conspiracy and bribery, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a ten times fine and hereditary disenfranchisement, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">δώρων γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">δώρων γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for conspiracy and bribery, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a ten times fine and hereditary disenfranchisement, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 2.3: "ἀλλ᾽ οἶμαι Δημοσθένης οὐ χαίρει δικαίοις λόγοις, οὐδ᾽ οὕτω παρεσκεύασται, ἀλλὰ τὴν ὑμετέραν ὀργὴν ἐκκαλέσασθαι βεβούληται. καὶ κατηγόρηκε δωροδοκίας, ἀπίθανος ὢν πρὸς τὴν ὑποψίαν ταύτην: τὸν γὰρ ἐπὶ ταῖς δωροδοκίαις προτρεπόμενον ὀργίζεσθαι, αὐτὸν χρὴ τῶν τοιούτων ἔργων ἀπέχεσθαι."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q95598538"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_providing_false_witness_testimony_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">false witness suit</rdfs:label>
        <skos:prefLabel xml:lang="en">false witness suit</skos:prefLabel>
        <skos:definition xml:lang="en">Private lawsuit for providing false witness testimony, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <rdfs:label xml:lang="grc">ψευδομαρτυριῶν δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">ψευδομαρτυριῶν δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι ἴδιαι for providing false witness testimony, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
        <skos:example xml:lang="grc">Dem. 24.131: "οὐδὲ γὰρ οἱ τῆς ξενίας ἁλισκόμενοι ἀγανακτοῦσιν ἐν τῷ οἰκήματι τούτῳ ὄντες, ἕως ἂν τῶν ψευδομαρτυριῶν ἀγωνίσωνται, ἀλλὰ μένουσιν καὶ οὐκ οἴονται δεῖν ἐγγυητὰς καταστήσαντες περιιέναι."</skos:example>
        <skos:example xml:lang="grc">Isaeus 11.46: "δίκαι γὰρ ἐνεστήκασι ψευδομαρτυρίων, κελεύει δ᾽ ὁ νόμος, ἐὰν ἁλῷ τις τῶν ψευδομαρτυρίων, πάλιν ἐξ ἀρχῆς εἶναι περὶ αὐτῶν τὰς λήξεις: τὰ δὲ τοῦ παιδὸς ὡμολογημένα καὶ ἀναμφισβήτητα καταλέλοιπε Στρατοκλῆς. ὅτι δὲ τοσαῦτά ἐστι τἀμὰ σὺν τοῖς τοῦ ἐκποιήτου ὑέος, καὶ ψευδομαρτυριῶν ἐνεστᾶσι δίκαι περὶ τῶν Ἁγνίου, λαβὲ τὰς μαρτυρίας καὶ ἀνάγνωθι."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_with_multiple_claimants_for_inheritance_dispute_initiated_by_competing_claims_for_inheritance_supervised_by_Eponymous_Archon_tried_by_the_dikasterion">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">lawsuit for adjudication</rdfs:label>
        <skos:prefLabel xml:lang="en">lawsuit for adjudication</skos:prefLabel>
        <skos:definition xml:lang="en">Lawsuit with multiple claimants, for inheritance dispute, initiated by competing claims for inheritance, supervised by Eponymous Archon, tried by the dikasterion.</skos:definition>
        <rdfs:label xml:lang="grc">διαδικασία</rdfs:label>
        <skos:prefLabel xml:lang="grc">διαδικασία</skos:prefLabel>
        <skos:definition xml:lang="grc">A δίκη with multiple claimants for an inheritance dispute, initiated by competing claims for inheritance, supervised by the Eponymous Archon and tried by the dikasterion.</skos:definition>
        <skos:example xml:lang="grc">Dem. 24.54: "ὅσων δίκη πρότερον ἐγένετο ἢ εὔθυνα ἢ διαδικασία περί του ἐν δικαστηρίῳ, ἢ ἰδίᾳ ἢ δημοσίᾳ, ἢ τὸ δημόσιον ἀπέδοτο, μὴ εἰσάγειν περὶ τούτων εἰς τὸ δικαστήριον μηδ᾽ ἐπιψηφίζειν τῶν ἀρχόντων μηδένα, μηδὲ κατηγορεῖν ἐώντων ἃ οὐκ ἐῶσιν οἱ νόμοι.”</skos:example>
        <skos:example xml:lang="grc">Dem. 43.61: "ἔστιν δ᾽ ὁ νῦν ἀγὼν καὶ ἡ διαδικασία οὐκ εἴ τις ἕτερος ἑτέρου πρότερος ἢ ὕστερος τετελεύτηκεν, ἀλλ᾽ εἰ μὴ προσήκει ἐξελαθῆναι ἐκ τοῦ οἴκου τοῦ Ἁγνίου τοὺς οἰκείους τοὺς Ἁγνίου, ἀνεψιοὺς ὄντας καὶ ἀνεψιῶν παῖδας Ἁγνίᾳ πρὸς πατρός, ὑπὸ τῶν ἐκ τοῦ Στρατίου οἴκου καὶ μηδὲν προσηκόντων ὥστε κληρονομεῖν τῶν Ἁγνίου, ἀλλὰ γένει ἀπωτέρω ὄντων. περὶ τούτου νῦν ἐσθ᾽ ὁ ἀγών."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q64224291"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty_for_intentional_homicide_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_death_and_confiscation_of_property">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">intentional homicide suit</rdfs:label>
        <skos:prefLabel xml:lang="en">intentional homicide suit</skos:prefLabel>
        <skos:definition xml:lang="en">Homicide suit for intentional homicide, tried by the Council of the Areopagus, has punishment for convicted of death and confiscation of property.</skos:definition>
        <rdfs:label xml:lang="grc">φόνος ἑκούσιος δίκη</rdfs:label>
        <skos:prefLabel xml:lang="grc">φόνος ἑκούσιος δίκη</skos:prefLabel>
        <skos:definition xml:lang="grc">Φόνος δίκη for intentional homicide, tried by the Council of the Areopagus, has punishment for convicted of death and confiscation of property.</skos:definition>
        <skos:example xml:lang="grc">Antiph. 3 3.7: "ἀκουσίως δὲ οὐχ ἧσσον ἢ ἑκουσίως ἀποκτείναντες1 μου τὸν παῖδα, τὸ παράπαν δ᾽ ἀρνούμενοι2 μὴ ἀποκτεῖναι αὐτόν, οὐδ᾽ ὑπὸ τοῦ νόμου καταλαμβάνεσθαί φασιν,3 ὃς ἀπαγορεύει μήτε δικαίως μήτε ἀδίκως ἀποκτείνειν. ἀλλὰ τίς ὁ βαλών; εἰς τίν᾽ ὁ φόνος ἀνήκει;4 εἰς τοὺς θεωμένους ἢ εἰς τοὺς παιδαγωγοὺς, ὧν οὐδεὶς οὐδὲν κατηγορεῖ; οὐ γὰρ ἀφανὴς ἀλλὰ καὶ λίαν φανερὸς ἔμοιγε αὐτοῦ ὁ θάνατός ἐστιν. ἐγὼ δὲ τὸν νόμον ὀρθῶς ἀγορεύειν φημὶ τοὺς ἀποκτείναντας κολάζεσθαι: ὅ τε γὰρ ἄκων ἀποκτείνας ἀκουσίοις κακοῖς περιπεσεῖν δίκαιός ἐστιν, ὅ τε διαφθαρεὶς οὐδὲν ἧσσον ἀκουσίως ἢ ἑκουσίως βλαφθεὶς ἀδικοῖτ᾽ ἂν ἀτιμώρητος γενόμενος."</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding_brought_forward_by_relatives_of_victim_defendant_summoned_by_proclamation_at_funeral_of_victim_initiated_with_a_proclamation_at_funeral_of_victim_supervised_by_Basileus_with_a_prosecutor_and_defendant_has_no_penalty_for_failed_prosecution_with_non-assessable_penalty"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_processes"/>
        <rdfs:label xml:lang="en">public lawsuit</rdfs:label>
        <skos:prefLabel xml:lang="en">public lawsuit</skos:prefLabel>
        <skos:definition xml:lang="en">Lawsuit brought forward by anyone who wishes, with a prosecutor and defendant.</skos:definition>
        <rdfs:label xml:lang="grc">δίκαι δημόσιαι</rdfs:label>
        <skos:prefLabel xml:lang="grc">δίκαι δημόσιαι</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκη brought forward by anyone who wishes, with a prosecutor and defendant.</skos:definition>
        <skos:example xml:lang="grc">Andoc. 1.9: " ὁρῶν ὑμᾶς καὶ ἐν τοῖς ἰδίοις καὶ ἐν τοῖς δημοσίοις περὶ πλείστου τοῦτο ποιουμένους"</skos:example>
        <skos:broader rdf:resource="#Legal_proceeding"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_inititated_by_plaintiff_denouncing_defendant_to_a_magistrate_for_arrest_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_initiated_by_plaintiff_arresting_defendant_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_evaluate_a_potential_magistrate_initiated_before_term_of_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_evaluate_term_in_office_initiated_automatically_after_term_of_magistrate_supervised_by_Euthynoi_tried_by_the_dikasterion_has_punishment_for_convicted_of_tenfold_damages_with_non-assessable_penalty"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_non-assessable_penalty_has_punishment_for_convicted_of_death_has_no_penalty_for_failed_prosecution"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_maltreatment_of_parents_orphans_and_heiresses_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
