    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_illicit_consensual_sex_with_a_woman_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment">
        <rdfs:label xml:lang="en">indictment for seduction</rdfs:label>
        <skos:prefLabel xml:lang="en">indictment for seduction</skos:prefLabel>
        <skos:definition xml:lang="en">Indictment for illicit consensual sex with a woman, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <rdfs:label xml:lang="grc">μοιχείας γραφή</rdfs:label>
        <skos:prefLabel xml:lang="grc">μοιχείας γραφή</skos:prefLabel>
        <skos:definition xml:lang="grc">Γραφή for illicit consensual sex with a woman, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <skos:example xml:lang="grc">Lys. 1.36: "οἷς ὑμᾶς ἀξιῶ τὴν αὐτὴν γνώμην ἔχειν: εἰ δὲ μή, τοιαύτην ἄδειαν τοῖς μοιχοῖς ποιήσετε, ὥστε1 καὶ τοὺς κλέπτας ἐπαρεῖτε φάσκειν μοιχοὺς εἶναι, εὖ εἰδότας ὅτι, ἐὰν ταύτην τὴν αἰτίαν περὶ ἑαυτῶν λέγωσι καὶ ἐπὶ τούτῳ φάσκωσιν εἰς τὰς ἀλλοτρίας οἰκίας εἰσιέναι, οὐδεὶς αὐτῶν ἅψεται. πάντες γὰρ εἴσονται ὅτι τοὺς μὲν νόμους τῆς μοιχείας χαίρειν ἐᾶν δεῖ, τὴν δὲ ψῆφον τὴν ὑμετέραν δεδιέναι: αὕτη γάρ ἐστι πάντων τῶν ἐν τῇ πόλει κυριωτάτη."</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_conspiracy_and_bribery_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_ten_times_fine_and_hereditary_disenfranchisement_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_destruction_of_sacred_olive_trees_supervised_by_Basileus_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_death_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_avoiding_military_service_supervised_by_Strategoi_tried_by_the_dikasterion_has_punishment_for_convicted_of_disenfranchisement_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_exercising_citizenship_rights_as_a_noncitizen_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_enslavement_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_intentional_wounding_with_a_weapon_supervised_by_Basileus_tried_by_the_Council_of_the_Areopagus_has_punishment_for_convicted_of_exile_and_confiscation_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_examine_disabled_pension_recipient_tried_by_the_Council_has_punishment_for_convicted_of_losing_pension"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_impiety_supervised_by_Basileus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_crimes_of_hubris_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_proposing_or_enacting_an_illegal_law_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_to_overturn_decision_of_a_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#for_illicit_consensual_sex_with_a_woman"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#supervised_by_the_Thesmothetai"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#tried_by_the_dikasterion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
