	<!--  OTV Concepts -->

    <otv:Concept rdf:about="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_for_theft_of_private_property_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_double_damages_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis">
