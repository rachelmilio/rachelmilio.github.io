            <ontolex:LexicalConcept rdf:about="#lexical_concept_ἀπογραφή_grc">
                <ontolex:isEvokedBy rdf:resource="#ἀπογραφή_grc"/>
                <skos:definition xml:lang="grc">Δίκαι δημόσιαι for withholding property from the state, defendant summoned by plaintiff via prosklesis, initiated by submitting an inventory of owed property, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of confiscation of owed property, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_withholding_property_from_the_state_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_an_inventory_of_owed_property_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_confiscation_of_owed_property_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
