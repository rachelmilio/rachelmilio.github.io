        <otv:containsDifference rdf:resource="#brought_forward_by_the_injured_party_or_a_guardian"/>
    </otv:AxisOfAnalysis>

    <otv:Difference rdf:about="#brought_forward_by_anyone_who_wishes">
        <rdf:type rdf:resource="http://www.ontologia.fr/OTB/otv#Difference"/>
        <rdfs:label>brought forward by anyone who wishes</rdfs:label>
        <otv:belongsToAxis rdf:resource="#Who_can_bring_forward"/>
    </otv:Difference>

