    <otv:Term rdf:about="#εἰσαγγελία_grc">
        <rdfs:label xml:lang="grc">εἰσαγγελία</rdfs:label>
        <otv:termName>εἰσαγγελία</otv:termName>
        <otv:language>grc</otv:language>
        <otv:denotedConcept rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_non-assessable_penalty_has_punishment_for_convicted_of_death_has_no_penalty_for_failed_prosecution"/>
        <otv:termStatus>preferred</otv:termStatus>
        <otv:partOfSpeech>none</otv:partOfSpeech>
        <otv:gender>none</otv:gender>
        <otv:termDefinition>Δίκαι δημόσιαι for subversion or treason or bribery of public speakers, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, with non-assessable penalty, has punishment for convicted of death, has no penalty for failed prosecution.</otv:termDefinition>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for subversion or treason or bribery of public speakers, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by the Thesmothetai, tried by the dikasterion, with non-assessable penalty, has punishment for convicted of death, has no penalty for failed prosecution.</skos:definition>
        <otv:context xml:lang="grc">Andoc. 1.43: "ἡ μὲν εἰσαγγελία αὐτῷ, ὦ ἄνδρες, τοιαύτη: ἀπογράφει δὲ τὰ ὀνόματα τῶν ἀνδρῶν ὧν ἔφη γνῶναι, δύο καὶ τετταράκοντα, πρώτους μὲν Μαντίθεον καὶ Ἀψεφίωνα, βουλευτὰς ὄντας καὶ καθημένους ἔνδον, εἶτα δὲ καὶ τοὺς ἄλλους. ἀναστὰς δὲ Πείσανδρος ἔφη χρῆναι λύειν τὸ ἐπὶ Σκαμανδρίου ψήφισμα καὶ ἀναβιβάζειν ἐπὶ τὸν τροχὸν τοὺς ἀπογραφέντας, ὅπως μὴ πρότερον νὺξ ἔσται πρὶν πυθέσθαι τοὺς ἄνδρας ἅπαντας. ἀνέκραγεν ἡ βουλὴ ὡς εὖ λέγει."</otv:context>
        <otv:context xml:lang="grc">Dem. 21.121: "Λυσίμαχος Ἀλωπεκῆθεν, Δημέας Σουνιεύς, Χάρης Θορίκιος, Φιλήμων Σφήττιος, Μόσχος Παιανιεύς, καθ᾽ οὓς καιροὺς ἡ εἰσαγγελία ἐδόθη εἰς τὴν βουλὴν ὑπὲρ Ἀριστάρχου τοῦ Μόσχου, ὅτι εἴη Νικόδημον ἀπεκτονώς, οἴδαμεν Μειδίαν τὸν κρινόμενον ὑπὸ Δημοσθένους, ᾧ μαρτυροῦμεν, ἐλθόντα πρὸς τὴν βουλὴν καὶ λέγοντα μηδένα ἕτερον εἶναι τὸν Νικοδήμου φονέα, ἀλλ᾽ Ἀρίσταρχον, καὶ τοῦτον αὐτοῦ γεγονέναι αὐτόχειρα, καὶ συμβουλεύοντα τῇ βουλῇ βαδίζειν ἐπὶ τὴν οἰκίαν τὴν Ἀριστάρχου καὶ συλλαμβάνειν αὐτόν."</otv:context>
    </otv:Term>

    <otv:Term rdf:about="#παρανόμων γραφή_grc">
        <rdfs:label xml:lang="grc">παρανόμων γραφή</rdfs:label>
        <otv:termName>παρανόμων γραφή</otv:termName>
        <otv:language>grc</otv:language>
        <otv:denotedConcept rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_proposing_or_enacting_an_illegal_law_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment"/>
        <otv:termStatus>preferred</otv:termStatus>
        <otv:partOfSpeech>none</otv:partOfSpeech>
        <otv:gender>none</otv:gender>
        <otv:termDefinition>Γραφή for proposing or enacting an illegal law, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</otv:termDefinition>
        <skos:definition xml:lang="grc">Γραφή for proposing or enacting an illegal law, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <otv:context xml:lang="grc">Dem. 18.13: " ἀλλ᾽ ἐφ᾽ οἷς ἀδικοῦντά μ᾽ ἑώρα τὴν πόλιν, οὖσί γε τηλικούτοις ἡλίκα νῦν ἐτραγῴδει καὶ διεξῄει, ταῖς ἐκ τῶν νόμων τιμωρίαις παρ᾽ αὐτὰ τἀδικήματα χρῆσθαι, εἰ μὲν εἰσαγγελίας ἄξια πράττονθ᾽ ἑώρα, εἰσαγγέλλοντα καὶ τοῦτον τὸν τρόπον εἰς κρίσιν καθιστάντα παρ᾽ ὑμῖν, εἰ δὲ γράφοντα παράνομα, παρανόμων γραφόμενον"</otv:context>
    </otv:Term>

    <otv:Term rdf:about="#δώρων_γραφή_grc">
        <rdfs:label xml:lang="grc">δώρων γραφή</rdfs:label>
        <otv:termName>δώρων γραφή</otv:termName>
        <otv:language>grc</otv:language>
        <otv:denotedConcept rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_conspiracy_and_bribery_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_ten_times_fine_and_hereditary_disenfranchisement_with_non-assessable_penalty"/>
        <otv:termStatus>preferred</otv:termStatus>
        <otv:partOfSpeech>none</otv:partOfSpeech>
        <otv:gender>none</otv:gender>
        <otv:termDefinition>Γραφή for conspiracy and bribery, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a ten times fine and hereditary disenfranchisement, with non-assessable penalty.</otv:termDefinition>
        <skos:definition xml:lang="grc">Γραφή for conspiracy and bribery, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of a ten times fine and hereditary disenfranchisement, with non-assessable penalty.</skos:definition>
        <otv:context xml:lang="grc">Aeschin. 2.3: "ἀλλ᾽ οἶμαι Δημοσθένης οὐ χαίρει δικαίοις λόγοις, οὐδ᾽ οὕτω παρεσκεύασται, ἀλλὰ τὴν ὑμετέραν ὀργὴν ἐκκαλέσασθαι βεβούληται. καὶ κατηγόρηκε δωροδοκίας, ἀπίθανος ὢν πρὸς τὴν ὑποψίαν ταύτην: τὸν γὰρ ἐπὶ ταῖς δωροδοκίαις προτρεπόμενον ὀργίζεσθαι, αὐτὸν χρὴ τῶν τοιούτων ἔργων ἀπέχεσθαι."</otv:context>
    </otv:Term>

    <otv:Term rdf:about="#ὕβρεως_γραφή_grc">
        <rdfs:label xml:lang="grc">ὕβρεως γραφή</rdfs:label>
        <otv:termName>ὕβρεως γραφή</otv:termName>
        <otv:language>grc</otv:language>
        <otv:denotedConcept rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_crimes_of_hubris_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_with_assessable_penalty_through_timesis_has_punishment_for_convicted_of_a_penal_assessment"/>
        <otv:termStatus>preferred</otv:termStatus>
        <otv:partOfSpeech>none</otv:partOfSpeech>
        <otv:gender>none</otv:gender>
        <otv:termDefinition>Γραφή for crimes of hubris, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</otv:termDefinition>
        <skos:definition xml:lang="grc">Γραφή for crimes of hubris, supervised by the Thesmothetai, tried by the dikasterion, with assessable penalty through timesis, has punishment for convicted of a penal assessment.</skos:definition>
        <otv:context xml:lang="grc">Dem. 37.33: "ἐνταυθὶ πόλλ᾽ ἄττα καὶ δεινά μοι ἅμ᾽ ἐγκαλεῖ: καὶ γὰρ αἴκειαν καὶ ὕβριν καὶ βιαίων καὶ πρὸς ἐπικλήρους ἀδικήματα. τούτων δ᾽ εἰσὶν ἑκάστου χωρὶς αἱ δίκαι καὶ οὔτε πρὸς ἀρχὴν τὴν αὐτὴν οὔθ᾽ ὑπὲρ τιμημάτων τῶν αὐτῶν, ἀλλ᾽ ἡ μὲν αἴκεια καὶ τὰ τῶν βιαίων πρὸς τοὺς τετταράκοντα, αἱ δὲ τῆς ὕβρεως πρὸς τοὺς θεσμοθέτας, ὅσα δ᾽ εἰς ἐπικλήρους, πρὸς τὸν ἄρχοντα. οἱ δὲ νόμοι καὶ τούτων διδόασι τὰς παραγραφὰς ἀντιλαγχάνειν, περὶ ὧν οὐκ εἰσὶν εἰσαγωγεῖς. λέγε δ᾽ αὐτοῖς τουτονὶ τὸν νόμον."</otv:context>
    </otv:Term>

    <otv:Term rdf:about="#δοκιμασία_τῶν_ῥητόρων_grc">
        <rdfs:label xml:lang="grc">δοκιμασία τῶν ῥητόρων</rdfs:label>
