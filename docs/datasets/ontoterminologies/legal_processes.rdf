    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_inititated_by_plaintiff_denouncing_defendant_to_a_magistrate_for_arrest_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty">
        <rdfs:label xml:lang="en">denunciation</rdfs:label>
        <skos:prefLabel xml:lang="en">denunciation</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit for theft or murder or illegal exercise of citizen rights, defendant summoned by arrest, inititated by plaintiff denouncing defendant to a magistrate for arrest, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <rdfs:label xml:lang="grc">ἔνδειξις</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἔνδειξις</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for theft or murder or illegal exercise of citizen rights, defendant summoned by arrest, inititated by plaintiff denouncing defendant to a magistrate for arrest, supervised by the Eleven, tried by the dikasterion, has punishment for convicted of death, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
        <skos:example xml:lang="grc">Andoc. 1.10: "ὥσπερ δὲ καὶ προεῖπον ὑμῖν, ὦ ἄνδρες, ἐξ ἀρχῆς περὶ πάντων ποιήσομαι τὴν ἀπολογίαν, πρῶτον μὲν περὶ αὐτῆς τῆς αἰτίας ὅθεν περ ἡ ἔνδειξις ἐγένετο, διόπερ εἰς τὸν ἀγῶνα τόνδε κατέστην, περὶ τῶν μυστηρίων"</skos:example>
        <skos:example xml:lang="grc">Dem. 24.22: "ἐὰν δ᾽ οἱ πρυτάνεις μὴ ποιήσωσι κατὰ τὰ γεγραμμένα τὴν ἐκκλησίαν ἢ οἱ πρόεδροι μὴ χρηματίσωσι, ὀφείλειν τῶν μὲν πρυτάνεων ἕκαστον χιλίας δραχμὰς ἱερὰς τῇ Ἀθηνᾷ, τῶν δὲ προέδρων ἕκαστος ὀφειλέτω τετταράκοντα δραχμὰς ἱερὰς τῇ Ἀθηνᾷ. καὶ ἔνδειξις αὐτῶν ἔστω πρὸς τοὺς θεσμοθέτας, καθάπερ ἐάν τις ἄρχῃ ὀφείλων τῷ δημοσίῳ: οἱ δὲ θεσμοθέται τοὺς ἐνδειχθέντας εἰσαγόντων εἰς τὸ δικαστήριον κατὰ τὸν νόμον, ἢ μὴ ἀνιόντων εἰς Ἄρειον πάγον, ὡς καταλύοντες τὴν ἐπανόρθωσιν τῶν νόμων."</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_subversion_or_treason_or_bribery_of_public_speakers_initiated_by_investigation_by_the_Council_of_the_Areopagus_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_defendant_summoned_by_proclamation_in_the_Assembly_initiated_by_vote_before_the_Assembly_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_a_penal_assessment_has_penalty_of_1000_drachmas_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
