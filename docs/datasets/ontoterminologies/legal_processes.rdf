                <ontolex:isEvokedBy rdf:resource="#δίκη_προικός_grc"/>
                <skos:definition xml:lang="grc">Δίκαι ἴδιαι to claim full amount of a dowry, defendant summoned by plaintiff via prosklesis, initiated by submitting a charge in writing to magistrate, supervised by Eponymous Archon, tried by the dikasterion, has punishment for convicted of an assessable fine, has penalty of epobelia for failed prosecution, with assessable penalty through timesis.</skos:definition>
            </ontolex:LexicalConcept>
        </ontolex:evokes>
        <ontolex:denotes rdf:resource="#Legal_proceeding_brought_forward_by_the_injured_party_or_a_guardian_with_a_prosecutor_and_defendant_to_claim_full_amount_of_a_dowry_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_penalty_of_epobelia_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
    </ontolex:LexicalEntry>

    <ontolex:LexicalEntry rdf:about="#ἀπογραφή_grc">
        <ontolex:lexicalForm>
            <ontolex:Form rdf:about="#form_ἀπογραφή_grc">
                <ontolex:writtenRep xml:lang="grc">ἀπογραφή</ontolex:writtenRep>
            </ontolex:Form>
