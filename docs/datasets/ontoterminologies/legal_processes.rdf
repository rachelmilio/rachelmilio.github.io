        <otv:termStatus>preferred</otv:termStatus>
        <otv:partOfSpeech>none</otv:partOfSpeech>
        <otv:gender>none</otv:gender>
        <otv:termDefinition>Δίκαι δημόσιαι for illegally addressing the Assembly, defendant summoned by proclamation in the Assembly, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of disenfranchisement, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</otv:termDefinition>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι for illegally addressing the Assembly, defendant summoned by proclamation in the Assembly, supervised by the Thesmothetai, tried by the dikasterion, has punishment for convicted of disenfranchisement, has penalty of 1000 drachmas for failed prosecution, with non-assessable penalty.</skos:definition>
    </otv:Term>

    <otv:Term rdf:about="#ἀπόφασις_grc">
