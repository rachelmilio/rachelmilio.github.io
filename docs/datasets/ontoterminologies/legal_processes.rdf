    <owl:Class rdf:about="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_evaluate_a_potential_magistrate_initiated_before_term_of_magistrate_supervised_by_the_Thesmothetai_tried_by_the_dikasterion">
        <rdfs:label xml:lang="en">scrutiny</rdfs:label>
        <skos:prefLabel xml:lang="en">scrutiny</skos:prefLabel>
        <skos:definition xml:lang="en">Public lawsuit to evaluate a potential magistrate, initiated before term of magistrate, supervised by the Thesmothetai, tried by the dikasterion.</skos:definition>
        <rdfs:label xml:lang="grc">δοκιμασία</rdfs:label>
        <skos:prefLabel xml:lang="grc">δοκιμασία</skos:prefLabel>
        <skos:definition xml:lang="grc">Δίκαι δημόσιαι to evaluate a potential magistrate, initiated before term of magistrate, supervised by the Thesmothetai, tried by the dikasterion.</skos:definition>
        <skos:example xml:lang="grc">Aeschin. 1.28: "τίνας δ᾽ οὐκ ᾤετο δεῖν λέγειν; τοὺς αἰσχρῶς βεβιωκότας: τούτους οὐκ ἐᾷ δημηγορεῖν. καὶ ποῦ τοῦτο δηλοῖ; ‘δοκιμασία,’ φησί, ‘ῥητόρων: ἐάν τις λέγῃ ἐν τῷ δήμῳ τὸν πατέρα τύπτων ἢ τὴν μητέρα, ἢ μὴ τρέφων, ἢ μὴ παρέχων οἴκησιν:’ τοῦτον οὐκ ἐᾷ λέγειν. νὴ Δία καλῶς γε, ὡς ἔγωγέ φημι. διὰ τί; ὅτι εἴ τις, οὓς ἐξ ἴσου δεῖ τιμᾶν τοῖς θεοῖς, εἰς τούτους ἐστὶ φαῦλος, τί ποτε, φησίν, ὑπ᾽ αὐτοῦ πείσονται οἱ ἀλλότριοι καὶ ἡ πόλις ὅλη; καὶ τίσι δεύτερον ἀπεῖπε μὴ λέγειν; ‘ἢ τὰς στρατείας,’"</skos:example>
        <skos:example xml:lang="grc">Lys. 26.16: "καίτοιγε αὐτὸν ἀκούω λέξειν ὡς οὐ περὶ αὐτοῦ μόνον ἡ δοκιμασία ἐστίν, ἀλλὰ περὶ πάντων τῶν ἐν ἄστει μεινάντων, καὶ τοὺς ὅρκους καὶ τὰς συνθήκας ὑμᾶς ὑπομνήσειν, ὡς ἐκ τούτων προσληψόμενον αὐτὸν δοκιμαστὰς τοὺς ἐν ἄστει μείναντας. ἐγὼ δ᾽ ὑπὲρ τοῦ πλήθους βραχέα πρὸς αὐτὸν εἰπεῖν βούλομαι, ὅτι ὁ δῆμος οὐ τὴν αὐτὴν γνώμην ἔχει περὶ πάντων τῶν ἐν ἄστει μεινάντων, ἀλλὰ περὶ μὲν τῶν τοιαῦτα ἐξαμαρτανόντων οἵαν ἐγώ φημι δεῖν,"</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_examine_disabled_pension_recipient_tried_by_the_Council_has_punishment_for_convicted_of_losing_pension"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_maltreatment_of_parents_orphans_and_heiresses_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_a_charge_in_writing_to_magistrate_supervised_by_Eponymous_Archon_tried_by_the_dikasterion_has_punishment_for_convicted_of_an_assessable_fine_has_no_penalty_for_failed_prosecution_with_assessable_penalty_through_timesis"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_to_evaluate_term_in_office_initiated_automatically_after_term_of_magistrate_supervised_by_Euthynoi_tried_by_the_dikasterion_has_punishment_for_convicted_of_tenfold_damages_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_initiated_by_plaintiff_arresting_defendant_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_withholding_property_from_the_state_defendant_summoned_by_plaintiff_via_prosklesis_initiated_by_submitting_an_inventory_of_owed_property_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_confiscation_of_owed_property_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
        <owl:disjointWith rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_for_theft_or_murder_or_illegal_exercise_of_citizen_rights_defendant_summoned_by_arrest_inititated_by_plaintiff_denouncing_defendant_to_a_magistrate_for_arrest_supervised_by_the_Eleven_tried_by_the_dikasterion_has_punishment_for_convicted_of_death_has_penalty_of_1000_drachmas_for_failed_prosecution_with_non-assessable_penalty"/>
