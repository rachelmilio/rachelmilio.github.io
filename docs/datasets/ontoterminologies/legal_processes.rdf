        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_exercising_citizenship_rights_as_a_noncitizen_supervised_by_the_Thesmothetai_tried_by_the_dikasterion_has_punishment_for_convicted_of_enslavement_with_non-assessable_penalty"/>
        <skos:narrower rdf:resource="#Legal_proceeding_brought_forward_by_anyone_who_wishes_with_a_prosecutor_and_defendant_initiated_by_submitting_a_charge_in_writing_to_magistrate_defendant_summoned_by_plaintiff_via_prosklesis_has_penalty_of_1000_drachmas_for_failed_prosecution_for_avoiding_military_service_supervised_by_Strategoi_tried_by_the_dikasterion_has_punishment_for_convicted_of_disenfranchisement_with_non-assessable_penalty"/>
