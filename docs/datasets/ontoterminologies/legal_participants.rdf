            <ontolex:Form rdf:about="#form_φεύγων_grc">
                <ontolex:writtenRep xml:lang="grc">φεύγων</ontolex:writtenRep>
            </ontolex:Form>
        </ontolex:lexicalForm>
        <ontolex:evokes>
            <ontolex:LexicalConcept rdf:about="#lexical_concept_φεύγων_grc">
                <ontolex:isEvokedBy rdf:resource="#φεύγων_grc"/>
                <skos:definition xml:lang="grc">ἀντίδικος who has lawsuit initiated against by other, can be any gender or citizenship status, receives a punishment if convicted.</skos:definition>
