    <owl:Class rdf:about="#Legal_Participants_is_able_to_win_or_lose_legal_suit_makes_a_competing_claim_for_an_inheritance_must_be_an_adult_male_citizen_loses_deposit_if_decision_is_unfavorable">
        <rdfs:label xml:lang="en">claimant</rdfs:label>
        <skos:prefLabel xml:lang="en">claimant</skos:prefLabel>
        <skos:definition xml:lang="en">Litigant who makes a competing claim for an inheritance, must be an adult male citizen, loses deposit if decision is unfavorable.</skos:definition>
        <rdfs:label xml:lang="grc">ἀμφισβητῶν</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀμφισβητῶν</skos:prefLabel>
        <skos:definition xml:lang="grc">ἀντίδικος who makes a competing claim for an inheritance, must be an adult male citizen, loses deposit if decision is unfavorable.</skos:definition>
        <skos:example xml:lang="grc">"οὐ γὰρ δήπου συκοφαντεῖν γε βουλόμενος ἀπέγραψα μὲν ἂν πένθ᾽ ἡμιμναίων ἄξια ἀνδράποδα, ὡς αὐτὸς ὁ ἀμφισβητῶν τετίμηται αὐτά, ἐκινδύνευον δ᾽ ἂν περί τε χιλίων δραχμῶν καὶ τοῦ μηδέποτε μηδένα αὖθις ὑπὲρ ἐμαυτοῦ γράψασθαι:" (Dem. 53.1)</skos:example>
        <rdfs:subClassOf rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit"/>
        <owl:disjointWith rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit_initiates_lawsuit_against_another_must_be_an_adult_male_citizen_or_metic_receives_a_monetary_penalty_if_prosecution_fails"/>
        <owl:disjointWith rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit_has_lawsuit_initiated_against_by_other_can_be_any_gender_or_citizenship_status_receives_a_punishment_if_convicted"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#who_makes_a_competing_claim_for_an_inheritance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#must_be_an_adult_male_citizen"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#loses_deposit_if_decision_is_unfavorable"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

