	<!--  SKOS Concept Scheme -->

    <skos:ConceptScheme rdf:about="http://www.ontologia.fr/OTB/legal_participants">
        <dc:title>Athenian-Legal-Participants</dc:title>
        <dc:description>This is version 2.0 of a database for the PhD "Semantic Annotation and Attic Oratory" that defines the terms used to designate participants in Classical Athenian courts c. 419 BC to 323 BC. I define a legal participant as a person involved in a court proceeding without being an appointed or elected official. This work draws upon the corpus of Attic oratory as well as The Law of Ancient Athens by David D. Phillips and the Shape of Athenian Law by S.C. Todd. </dc:description>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-04-02</dc:issued>
        <dc:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-10-10</dc:modified>
        <dc:creator>Rachel Milio</dc:creator>
        <dc:publisher>University of Crete</dc:publisher>
    </skos:ConceptScheme>

	<!--  SKOS Concepts -->

    <skos:Concept rdf:about="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_witnesses_the_plaintiff_summoning_the_defendant_must_be_an_adult_male_citizen_can_be_prosecuted_for_dishonesty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <rdfs:label xml:lang="en">summons-witness</rdfs:label>
        <skos:prefLabel xml:lang="en">summons-witness</skos:prefLabel>
        <skos:definition xml:lang="en">Legal participant who participates in suit but is not directly affected by outcome, witnesses the plaintiff summoning the defendant, must be an adult male citizen, can be prosecuted for dishonesty.</skos:definition>
        <rdfs:label xml:lang="grc">κλητήρ</rdfs:label>
        <skos:prefLabel xml:lang="grc">κλητήρ</skos:prefLabel>
        <skos:definition xml:lang="grc">Legal participant who participates in suit but is not directly affected by outcome, witnesses the plaintiff summoning the defendant, must be an adult male citizen, can be prosecuted for dishonesty.</skos:definition>
        <skos:broader rdf:resource="#Legal_Participants"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Participants_is_able_to_win_or_lose_legal_suit_initiates_lawsuit_against_another_must_be_an_adult_male_citizen_or_metic_receives_a_monetary_penalty_if_prosecution_fails">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <rdfs:label xml:lang="en">prosecutor</rdfs:label>
        <skos:altLabel xml:lang="en">prosecutor</skos:altLabel>
        <skos:definition xml:lang="en">Litigant who initiates lawsuit against another, must be an adult male citizen or metic, receives a monetary penalty if prosecution fails.</skos:definition>
        <rdfs:label xml:lang="en">plaintiff</rdfs:label>
        <skos:prefLabel xml:lang="en">plaintiff</skos:prefLabel>
        <skos:definition xml:lang="en">Litigant who initiates lawsuit against another, must be an adult male citizen or metic, receives a monetary penalty if prosecution fails.</skos:definition>
        <rdfs:label xml:lang="grc">διώκων</rdfs:label>
        <skos:prefLabel xml:lang="grc">διώκων</skos:prefLabel>
        <skos:definition xml:lang="grc">ἀντίδικος who initiates lawsuit against another, must be an adult male citizen or metic, receives a monetary penalty if prosecution fails.</skos:definition>
        <skos:broader rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Participants_is_able_to_win_or_lose_legal_suit">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <rdfs:label xml:lang="en">litigant</rdfs:label>
        <skos:prefLabel xml:lang="en">litigant</skos:prefLabel>
        <skos:definition xml:lang="en">Legal participant who is able to win or lose legal suit.</skos:definition>
        <rdfs:label xml:lang="grc">ἀντίδικος</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀντίδικος</skos:prefLabel>
        <skos:definition xml:lang="grc">Legal participant who is able to win or lose legal suit.</skos:definition>
        <skos:broader rdf:resource="#Legal_Participants"/>
        <skos:narrower rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit_initiates_lawsuit_against_another_must_be_an_adult_male_citizen_or_metic_receives_a_monetary_penalty_if_prosecution_fails"/>
        <skos:narrower rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit_has_lawsuit_initiated_against_by_other_can_be_any_gender_or_citizenship_status_receives_a_punishment_if_convicted"/>
        <skos:narrower rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit_makes_a_competing_claim_for_an_inheritance_must_be_an_adult_male_citizen_loses_deposit_if_decision_is_unfavorable"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_gives_testimony_in_court_through_witness_depositions_to_support_litigant_must_be_an_adult_male_citizen_or_metic_can_be_prosecuted_for_dishonesty">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <rdfs:label xml:lang="en">witness</rdfs:label>
        <skos:prefLabel xml:lang="en">witness</skos:prefLabel>
        <skos:definition xml:lang="en">Legal participant who participates in suit but is not directly affected by outcome, gives testimony in court through witness depositions to support litigant, must be an adult male citizen or metic, can be prosecuted for dishonesty.</skos:definition>
        <rdfs:label xml:lang="grc">μάρτυς</rdfs:label>
        <skos:prefLabel xml:lang="grc">μάρτυς</skos:prefLabel>
        <skos:definition xml:lang="grc">Legal participant who participates in suit but is not directly affected by outcome, gives testimony in court through witness depositions to support litigant, must be an adult male citizen or metic, can be prosecuted for dishonesty.</skos:definition>
        <skos:broader rdf:resource="#Legal_Participants"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Participants">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <skos:topConceptOf rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <rdfs:label xml:lang="en">legal participant</rdfs:label>
        <skos:prefLabel xml:lang="en">legal participant</skos:prefLabel>
        <skos:definition xml:lang="en">.</skos:definition>
        <rdfs:label xml:lang="grc">legal participant</rdfs:label>
        <skos:prefLabel xml:lang="grc">legal participant</skos:prefLabel>
        <skos:definition xml:lang="grc">.</skos:definition>
        <skos:narrower rdf:resource="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_witnesses_the_plaintiff_summoning_the_defendant_must_be_an_adult_male_citizen_can_be_prosecuted_for_dishonesty"/>
        <skos:narrower rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit"/>
        <skos:narrower rdf:resource="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_delivers_supporting_speeches_for_litigant_must_be_an_adult_male_citizen"/>
        <skos:narrower rdf:resource="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_gives_testimony_in_court_through_witness_depositions_to_support_litigant_must_be_an_adult_male_citizen_or_metic_can_be_prosecuted_for_dishonesty"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Participants_is_able_to_win_or_lose_legal_suit_has_lawsuit_initiated_against_by_other_can_be_any_gender_or_citizenship_status_receives_a_punishment_if_convicted">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <rdfs:label xml:lang="en">defendant</rdfs:label>
        <skos:prefLabel xml:lang="en">defendant</skos:prefLabel>
        <skos:definition xml:lang="en">Litigant who has lawsuit initiated against by other, can be any gender or citizenship status, receives a punishment if convicted.</skos:definition>
        <rdfs:label xml:lang="grc">φεύγων</rdfs:label>
        <skos:prefLabel xml:lang="grc">φεύγων</skos:prefLabel>
        <skos:definition xml:lang="grc">ἀντίδικος who has lawsuit initiated against by other, can be any gender or citizenship status, receives a punishment if convicted.</skos:definition>
        <skos:broader rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_delivers_supporting_speeches_for_litigant_must_be_an_adult_male_citizen">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <rdfs:label xml:lang="en">synegoros</rdfs:label>
        <skos:altLabel xml:lang="en">synegoros</skos:altLabel>
        <skos:definition xml:lang="en">Legal participant who participates in suit but is not directly affected by outcome, delivers supporting speeches for litigant, must be an adult male citizen.</skos:definition>
        <rdfs:label xml:lang="en">advocate</rdfs:label>
        <skos:prefLabel xml:lang="en">advocate</skos:prefLabel>
        <skos:definition xml:lang="en">Legal participant who participates in suit but is not directly affected by outcome, delivers supporting speeches for litigant, must be an adult male citizen.</skos:definition>
        <rdfs:label xml:lang="grc">συνήγορος</rdfs:label>
        <skos:prefLabel xml:lang="grc">συνήγορος</skos:prefLabel>
        <skos:definition xml:lang="grc">Legal participant who participates in suit but is not directly affected by outcome, delivers supporting speeches for litigant, must be an adult male citizen.</skos:definition>
        <skos:broader rdf:resource="#Legal_Participants"/>
    </skos:Concept>

    <skos:Concept rdf:about="#Legal_Participants_is_able_to_win_or_lose_legal_suit_makes_a_competing_claim_for_an_inheritance_must_be_an_adult_male_citizen_loses_deposit_if_decision_is_unfavorable">
        <skos:inScheme rdf:resource="http://www.ontologia.fr/OTB/legal_participants"/>
        <rdfs:label xml:lang="en">claimant</rdfs:label>
        <skos:prefLabel xml:lang="en">claimant</skos:prefLabel>
        <skos:definition xml:lang="en">Litigant who makes a competing claim for an inheritance, must be an adult male citizen, loses deposit if decision is unfavorable.</skos:definition>
        <rdfs:label xml:lang="grc">ἀμφισβητῶν</rdfs:label>
        <skos:prefLabel xml:lang="grc">ἀμφισβητῶν</skos:prefLabel>
        <skos:definition xml:lang="grc">ἀντίδικος who makes a competing claim for an inheritance, must be an adult male citizen, loses deposit if decision is unfavorable.</skos:definition>
        <skos:example xml:lang="grc">"οὐ γὰρ δήπου συκοφαντεῖν γε βουλόμενος ἀπέγραψα μὲν ἂν πένθ᾽ ἡμιμναίων ἄξια ἀνδράποδα, ὡς αὐτὸς ὁ ἀμφισβητῶν τετίμηται αὐτά, ἐκινδύνευον δ᾽ ἂν περί τε χιλίων δραχμῶν καὶ τοῦ μηδέποτε μηδένα αὖθις ὑπὲρ ἐμαυτοῦ γράψασθαι:" (Dem. 53.1)</skos:example>
        <skos:broader rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit"/>
    </skos:Concept>

