    <owl:Class rdf:about="#Legal_Participants_is_able_to_win_or_lose_legal_suit_has_lawsuit_initiated_against_by_other_can_be_any_gender_or_citizenship_status_receives_a_punishment_if_convicted">
        <rdfs:label xml:lang="en">defendant</rdfs:label>
        <skos:prefLabel xml:lang="en">defendant</skos:prefLabel>
        <skos:definition xml:lang="en">Litigant who has lawsuit initiated against by other, can be any gender or citizenship status, receives a punishment if convicted.</skos:definition>
        <rdfs:label xml:lang="grc">φεύγων</rdfs:label>
        <skos:prefLabel xml:lang="grc">φεύγων</skos:prefLabel>
        <skos:definition xml:lang="grc">ἀντίδικος who has lawsuit initiated against by other, can be any gender or citizenship status, receives a punishment if convicted.</skos:definition>
        <rdfs:subClassOf rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit"/>
        <owl:disjointWith rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit_makes_a_competing_claim_for_an_inheritance_must_be_an_adult_male_citizen_loses_deposit_if_decision_is_unfavorable"/>
        <owl:disjointWith rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit_initiates_lawsuit_against_another_must_be_an_adult_male_citizen_or_metic_receives_a_monetary_penalty_if_prosecution_fails"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#who_has_lawsuit_initiated_against_by_other"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#can_be_any_gender_or_citizenship_status"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
                <owl:hasValue rdf:resource="#receives_a_punishment_if_convicted"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_delivers_supporting_speeches_for_litigant_must_be_an_adult_male_citizen">
        <rdfs:label xml:lang="en">synegoros</rdfs:label>
        <skos:altLabel xml:lang="en">synegoros</skos:altLabel>
        <skos:definition xml:lang="en">Legal participant who participates in suit but is not directly affected by outcome, delivers supporting speeches for litigant, must be an adult male citizen.</skos:definition>
        <rdfs:label xml:lang="en">advocate</rdfs:label>
        <skos:prefLabel xml:lang="en">advocate</skos:prefLabel>
        <skos:definition xml:lang="en">Legal participant who participates in suit but is not directly affected by outcome, delivers supporting speeches for litigant, must be an adult male citizen.</skos:definition>
        <rdfs:label xml:lang="grc">συνήγορος</rdfs:label>
        <skos:prefLabel xml:lang="grc">συνήγορος</skos:prefLabel>
        <skos:definition xml:lang="grc">Legal participant who participates in suit but is not directly affected by outcome, delivers supporting speeches for litigant, must be an adult male citizen.</skos:definition>
        <rdfs:subClassOf rdf:resource="#Legal_Participants"/>
        <owl:disjointWith rdf:resource="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_gives_testimony_in_court_through_witness_depositions_to_support_litigant_must_be_an_adult_male_citizen_or_metic_can_be_prosecuted_for_dishonesty"/>
        <owl:disjointWith rdf:resource="#Legal_Participants_participates_in_suit_but_is_not_directly_affected_by_outcome_witnesses_the_plaintiff_summoning_the_defendant_must_be_an_adult_male_citizen_can_be_prosecuted_for_dishonesty"/>
        <owl:disjointWith rdf:resource="#Legal_Participants_is_able_to_win_or_lose_legal_suit"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownDifference"/>
